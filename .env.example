# Copy to `.env` in this directory (or any parent of your cwd). `workspace-kit` loads the first
# `.env` found walking up from the current working directory. Existing shell env wins (not overridden).
#
# Used for: `init` / `upgrade` / `config` mutations (env lane) and post-completion hook `ingest`
# (merged into child `policyApproval`). See docs/maintainers/POLICY-APPROVAL.md

WORKSPACE_KIT_POLICY_APPROVAL={"confirmed":true,"rationale":"Local dev: kit mutations and transcript ingest hook"}
