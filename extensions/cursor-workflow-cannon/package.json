{
  "name": "cursor-workflow-cannon",
  "private": true,
  "displayName": "Workflow Cannon",
  "description": "Thin client UI for Workflow Cannon — dashboard, tasks, and config via workspace-kit CLI.",
  "version": "0.1.13",
  "publisher": "workflow-cannon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NJLaPrell/workflow-cannon.git",
    "directory": "extensions/cursor-workflow-cannon"
  },
  "type": "module",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.workspace-kit/manifest.json",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "files": [
    "dist",
    "media",
    "README.md",
    "SECURITY.md",
    "LICENSE",
    "package.json"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "workflow-cannon",
          "title": "Workflow Cannon",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "workflow-cannon": [
        {
          "type": "webview",
          "id": "workflowCannon.dashboard",
          "name": "Dashboard"
        },
        {
          "type": "webview",
          "id": "workflowCannon.config",
          "name": "Config"
        },
        {
          "type": "webview",
          "id": "workflowCannon.guidance",
          "name": "Guidance"
        }
      ]
    },
    "configuration": {
      "title": "Workflow Cannon",
      "properties": {
        "workflowCannon.nodeExecutable": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to `node` for running workspace-kit (must match the Node used for `pnpm install`, or native modules like `better-sqlite3` can fail with ABI/architecture errors). Leave empty to use `WORKSPACE_KIT_NODE`, workspace `.node-version` / `.nvmrc` through nvm, common install paths, then `node` on `PATH` — **not** the editor's embedded Node."
        }
      }
    },
    "commands": [
      {
        "command": "workflowCannon.openDashboard",
        "title": "Workflow Cannon: Open Dashboard"
      },
      {
        "command": "workflowCannon.showReadyQueue",
        "title": "Workflow Cannon: Show Ready Queue"
      },
      {
        "command": "workflowCannon.chat.prefillWishlistFlow",
        "title": "Workflow Cannon: Prefill Chat — Wishlist Intake Playbook"
      },
      {
        "command": "workflowCannon.chat.generateFeatures",
        "title": "Workflow Cannon: Generate Features"
      },
      {
        "command": "workflowCannon.openStatusDashboard",
        "title": "Workflow Cannon: Open Status Dashboard"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "check": "tsc -p ./ --noEmit",
    "package": "pnpm run compile",
    "test": "pnpm run compile && find test -name '*.test.mjs' -print0 | xargs -0 node --test"
  },
  "dependencies": {
    "@workflow-cannon/workspace-kit": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.9.3"
  }
}
