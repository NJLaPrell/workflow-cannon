{
  "name": "cursor-workflow-cannon",
  "private": true,
  "displayName": "Workflow Cannon",
  "description": "Thin client UI for Workflow Cannon — dashboard, tasks, and config via workspace-kit CLI.",
  "version": "0.1.14",
  "publisher": "workflow-cannon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NJLaPrell/workflow-cannon.git",
    "directory": "extensions/cursor-workflow-cannon"
  },
  "type": "module",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.workspace-kit/manifest.json",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "files": [
    "dist",
    "media",
    "README.md",
    "SECURITY.md",
    "LICENSE",
    "package.json"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "workflow-cannon",
          "title": "Workflow Cannon",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "workflow-cannon": [
        {
          "type": "webview",
          "id": "workflowCannon.dashboard",
          "name": "Dashboard"
        }
      ]
    },
    "configuration": {
      "title": "Workflow Cannon",
      "properties": {
        "workflowCannon.nodeExecutable": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to `node` for running workspace-kit. Leave empty to use `WORKSPACE_KIT_NODE`, Workflow Cannon's Node 22 runtime markers through nvm, common install paths, then `node` on `PATH`. The extension does not use the attached project's `.node-version` / `.nvmrc` unless you explicitly point this setting or `WORKSPACE_KIT_NODE` at that Node."
        },
        "workflowCannon.taskStateSync.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Run background git task-state sync (fetch/hydrate/apply) on an interval. Dashboard reads stay read-only."
        },
        "workflowCannon.taskStateSync.intervalMinutes": {
          "type": "number",
          "default": 5,
          "minimum": 0,
          "description": "Minutes between background task-state sync cycles (0 disables the interval; explicit refresh still works when enabled)."
        },
        "workflowCannon.taskStateSync.onGitHeadChange": {
          "type": "boolean",
          "default": true,
          "description": "When git HEAD changes (pull, merge, rebase, checkout), request background task-state sync immediately."
        }
      }
    },
    "commands": [
      {
        "command": "workflowCannon.openDashboard",
        "title": "Workflow Cannon: Open Dashboard"
      },
      {
        "command": "workflowCannon.showReadyQueue",
        "title": "Workflow Cannon: Show Ready Queue"
      },
      {
        "command": "workflowCannon.chat.prefillWishlistFlow",
        "title": "Workflow Cannon: Prefill Chat — Wishlist Intake Playbook"
      },
      {
        "command": "workflowCannon.chat.generateFeatures",
        "title": "Workflow Cannon: Generate Features"
      },
      {
        "command": "workflowCannon.chat.phaseNotesDiscovery",
        "title": "Workflow Cannon: Phase Notes Chat Guide"
      },
      {
        "command": "workflowCannon.openStatusDashboard",
        "title": "Workflow Cannon: Open Status Dashboard"
      },
      {
        "command": "workflowCannon.lease.pickAction",
        "title": "Workflow Cannon: Lease Actions"
      },
      {
        "command": "workflowCannon.lease.inspect",
        "title": "Workflow Cannon: Inspect Workspace Edit Lease"
      },
      {
        "command": "workflowCannon.lease.claim",
        "title": "Workflow Cannon: Claim Workspace Edit Lease"
      },
      {
        "command": "workflowCannon.lease.release",
        "title": "Workflow Cannon: Release Workspace Edit Lease"
      },
      {
        "command": "workflowCannon.lease.recover",
        "title": "Workflow Cannon: Recover Stale Workspace Edit Lease"
      },
      {
        "command": "workflowCannon.openGuidancePanel",
        "title": "Workflow Cannon: Open Guidance Authoring"
      },
      {
        "command": "workflowCannon.syncTaskState",
        "title": "Workflow Cannon: Sync Task State (Git)"
      },
      {
        "command": "workflowCannon.dashboard.restartService",
        "title": "Workflow Cannon: Restart Dashboard Service"
      },
      {
        "command": "workflowCannon.dashboard.useCliRefreshMode",
        "title": "Workflow Cannon: Use CLI Dashboard Refresh Mode"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "check": "tsc -p ./ --noEmit",
    "package": "pnpm run compile",
    "test": "pnpm run compile && find test -name '*.test.mjs' -print0 | xargs -0 node --test"
  },
  "dependencies": {
    "@workflow-cannon/workspace-kit": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.9.3"
  }
}
