{
  "name": "cursor-workflow-cannon",
  "private": true,
  "displayName": "Workflow Cannon",
  "description": "Thin client UI for Workflow Cannon — dashboard, tasks, and config via workspace-kit CLI.",
  "version": "0.1.12",
  "publisher": "workflow-cannon",
  "license": "MIT",
  "type": "module",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.workspace-kit/manifest.json",
    "onStartupFinished",
    "onCommand:workflowCannon.openDashboard",
    "onCommand:workflowCannon.refreshDashboard",
    "onCommand:workflowCannon.showReadyQueue",
    "onCommand:workflowCannon.refreshTasks",
    "onCommand:workflowCannon.validateConfig",
    "onCommand:workflowCannon.task.pickAction",
    "onCommand:workflowCannon.task.showDetail",
    "onCommand:workflowCannon.wishlist.showDetail",
    "onCommand:workflowCannon.task.start",
    "onCommand:workflowCannon.task.complete",
    "onCommand:workflowCannon.task.block",
    "onCommand:workflowCannon.task.pause",
    "onCommand:workflowCannon.task.unblock",
    "onCommand:workflowCannon.chat.prefillWishlistFlow",
    "onCommand:workflowCannon.chat.prefillImprovementTriage",
    "onCommand:workflowCannon.chat.prefillTaskToPhaseBranch",
    "onCommand:workflowCannon.chat.prefillTranscriptChurnResearch"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "workflow-cannon",
          "title": "Workflow Cannon",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "workflow-cannon": [
        {
          "type": "webview",
          "id": "workflowCannon.dashboard",
          "name": "Dashboard"
        },
        {
          "type": "webview",
          "id": "workflowCannon.config",
          "name": "Config"
        }
      ]
    },
    "configuration": {
      "title": "Workflow Cannon",
      "properties": {
        "workflowCannon.nodeExecutable": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to `node` for running workspace-kit (must match the Node used for `pnpm install`, or native modules like `better-sqlite3` will fail with MODULE_VERSION errors). Leave empty to use `WORKSPACE_KIT_NODE`, then common install paths, then `node` on `PATH` — **not** the editor's embedded Node."
        }
      }
    },
    "commands": [
      {
        "command": "workflowCannon.openDashboard",
        "title": "Workflow Cannon: Open Dashboard"
      },
      {
        "command": "workflowCannon.refreshDashboard",
        "title": "Workflow Cannon: Refresh Dashboard"
      },
      {
        "command": "workflowCannon.showReadyQueue",
        "title": "Workflow Cannon: Show Ready Queue"
      },
      {
        "command": "workflowCannon.refreshTasks",
        "title": "Workflow Cannon: Refresh Tasks"
      },
      {
        "command": "workflowCannon.validateConfig",
        "title": "Workflow Cannon: Validate Config"
      },
      {
        "command": "workflowCannon.task.pickAction",
        "title": "Workflow Cannon: Task Action"
      },
      {
        "command": "workflowCannon.task.showDetail",
        "title": "Workflow Cannon: Show Task Detail"
      },
      {
        "command": "workflowCannon.wishlist.showDetail",
        "title": "Workflow Cannon: Show Wishlist Detail"
      },
      {
        "command": "workflowCannon.task.start",
        "title": "Workflow Cannon: Start Task"
      },
      {
        "command": "workflowCannon.task.complete",
        "title": "Workflow Cannon: Complete Task"
      },
      {
        "command": "workflowCannon.task.block",
        "title": "Workflow Cannon: Block Task"
      },
      {
        "command": "workflowCannon.task.pause",
        "title": "Workflow Cannon: Pause Task"
      },
      {
        "command": "workflowCannon.task.unblock",
        "title": "Workflow Cannon: Unblock Task"
      },
      {
        "command": "workflowCannon.chat.prefillWishlistFlow",
        "title": "Workflow Cannon: Prefill Chat — Wishlist Intake Playbook"
      },
      {
        "command": "workflowCannon.chat.prefillImprovementTriage",
        "title": "Workflow Cannon: Prefill Chat — Improvement Triage (Top Three)"
      },
      {
        "command": "workflowCannon.chat.prefillTaskToPhaseBranch",
        "title": "Workflow Cannon: Prefill Chat — Task to Phase Branch Playbook"
      },
      {
        "command": "workflowCannon.chat.prefillTranscriptChurnResearch",
        "title": "Workflow Cannon: Prefill Chat — Transcript Churn Research (/research-churn)"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "check": "tsc -p ./ --noEmit",
    "package": "pnpm run compile",
    "test": "pnpm run compile && node --test test/**/*.test.mjs"
  },
  "dependencies": {
    "@workflow-cannon/workspace-kit": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.9.3"
  }
}
