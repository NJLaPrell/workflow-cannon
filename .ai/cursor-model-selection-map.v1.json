  "scopeDimensions": [
    {
      "id": "complexity",
      "label": "Code Complexity",
      "weight": "high",
      "description": "Algorithmic or architectural complexity of the code changes. Low: trivial patches. Medium: moderate logic. High: multi-layer design. Critical: novel architecture or deep algorithmic work.",
      "escalatesAt": "high"
    },
    {
      "id": "risk",
      "label": "Change Risk",
      "weight": "critical",
      "description": "Risk of breaking things, data loss, security impact, or API surface changes. Low: isolated file edits. Medium: shared utilities. High: auth/data paths. Critical: security, migrations, breaking public API.",
      "escalatesAt": "high"
    },
    {
      "id": "ambiguity",
      "label": "Requirement Ambiguity",
      "weight": "medium",
      "description": "How unclear or underspecified the task is. Low: crisp acceptance criteria. Medium: requires some interpretation. High: open-ended exploration. Critical: discovery-only with no known outcome.",
      "escalatesAt": "high"
    },
    {
      "id": "scope_breadth",
      "label": "Scope Breadth",
      "weight": "high",
      "description": "How many files, modules, or functional areas are touched. Low: 1–3 files. Medium: one subsystem. High: multiple subsystems or cross-cutting. Critical: repo-wide or multi-repo.",
      "escalatesAt": "high"
    }
  ],

  "selectionRules": [
    {
      "ruleId": "critical_risk",
      "priority": 100,
      "label": "Critical risk → specialist",
      "match": {
        "anyAtOrAbove": { "risk": "critical" }
      },
      "outcome": {
        "modelSlug": "claude-opus-4-8-thinking-high",
        "modelTier": "specialist",
        "rationale": "Critical risk task (security, data, breaking API) — Opus 4.8 specialist tier required.",
        "fallbackSlugs": ["claude-sonnet-5-thinking-high"]
      }
    },
    {
      "ruleId": "critical_complexity",
      "priority": 90,
      "label": "Critical complexity → specialist",
      "match": {
        "anyAtOrAbove": { "complexity": "critical" }
      },
      "outcome": {
        "modelSlug": "claude-opus-4-8-thinking-high",
        "modelTier": "specialist",
        "rationale": "Critically complex task — Opus 4.8 specialist tier required.",
        "fallbackSlugs": ["claude-sonnet-5-thinking-high"]
      }
    },
    {
      "ruleId": "bugbot_security",
      "priority": 85,
      "label": "Bugbot / security-review subagent type → specialist",
      "match": {
        "subagentTypes": ["bugbot", "security-review"]
      },
      "outcome": {
        "modelSlug": "claude-opus-4-8-thinking-high",
        "modelTier": "specialist",
        "rationale": "Bugbot and security-review subagents require specialist-tier reasoning for reliable audit quality.",
        "fallbackSlugs": ["claude-sonnet-5-thinking-high", "claude-4.6-sonnet-medium-thinking"]
      }
    },
    {
      "ruleId": "high_complexity_and_risk",
      "priority": 70,
      "label": "High complexity + high risk → high_reasoning",
      "match": {
        "allAtOrAbove": { "complexity": "high", "risk": "high" }
      },
      "outcome": {
        "modelTier": "high_reasoning",
        "rationale": "Both complexity and risk are elevated — high-reasoning model required.",
        "useTierDefault": true
      }
    },
    {
      "ruleId": "high_complexity_or_breadth",
      "priority": 60,
      "label": "High complexity or wide scope → high_reasoning",
      "match": {
        "anyAtOrAbove": { "complexity": "high", "scope_breadth": "high" }
      },
      "outcome": {
        "modelTier": "high_reasoning",
        "rationale": "High complexity or wide scope — high-reasoning model recommended.",
        "useTierDefault": true
      }
    },
    {
      "ruleId": "explore_shell_cheap",
      "priority": 50,
      "label": "Explore / shell subagent → cheap_fast",
      "match": {
        "subagentTypes": ["explore", "shell", "cursor-guide", "ci-investigator"]
      },
      "outcome": {
        "modelTier": "cheap_fast",
        "rationale": "Read-only or shell execution subagents don't need reasoning overhead — use cheap_fast tier.",
        "useTierDefault": true
      }
    },
    {
      "ruleId": "creative_task",
      "priority": 45,
      "label": "Creative task type hint → Fable 5 specialist",
      "match": {
        "taskTypeHints": ["creative", "narrative", "fiction", "creative-writing"]
      },
      "outcome": {
        "modelSlug": "claude-fable-5-thinking-high",
        "modelTier": "specialist",
        "rationale": "Creative or narrative tasks — Claude Fable 5 is the designated model.",
        "fallbackSlugs": ["claude-opus-4-8-thinking-high"]
      }
    },
    {
      "ruleId": "default",
      "priority": 10,
      "label": "Default — balanced tier",
      "match": {},
      "outcome": {
        "modelTier": "balanced",
        "rationale": "No elevated signals — balanced tier is appropriate.",
        "useTierDefault": true
      }
    }
  ],

