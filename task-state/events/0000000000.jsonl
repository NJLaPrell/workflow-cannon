{"schemaVersion":1,"eventId":"evt-152f53dc-d588-4cff-b8a2-aae3f6ad1dd6","sequence":2812,"parentEventId":"evt-3708ccf3-ea41-4cd0-aec0-c68c7dd2ff9d","recordedAt":"2026-07-09T18:19:33.776Z","actor":{"id":"workspace-kit","source":"system"},"command":{"name":"delete-idea","moduleId":"ideas"},"kind":"planning.idea.updated","payload":{"idea":{"id":"I005","title":"Brainstorm","note":"Idea -> Brainstorm -> Plan\nIdeas have a \"Brainstorm\" button instead of a plan button. Then we replace the \"New\" plan rollup with a \"Brainstorming\" rollup. Show only our brainstorming metrics (Risk/Value/etc)","status":"open","sortOrder":4,"linkedPlanArtifact":"plan-artifact:f7a3b891-c5d2-4e6f-9a08-1b2c3d4e5f60","previousPlanArtifacts":[],"createdAt":"2026-07-01T07:19:05.620Z","updatedAt":"2026-07-03T08:40:51.384Z"},"removed":true}}
{"schemaVersion":1,"eventId":"evt-7168ab7b-ad8d-4baf-8fee-41dcf46a0867","sequence":2813,"parentEventId":"evt-152f53dc-d588-4cff-b8a2-aae3f6ad1dd6","recordedAt":"2026-07-09T18:24:22.330Z","actor":{"id":"workspace-kit","source":"system"},"command":{"name":"update-idea","moduleId":"ideas"},"kind":"planning.idea.updated","payload":{"idea":{"id":"I009","title":"Make brainstorming a real guided ideation session that seeds the plan","note":"# Problem\nIdeas brainstorming is a scoring survey, not guided ideation.\n\n# Goal\nGuided ideation chat that seeds the plan draft.\n\n# Execution policy\nWBS materializes tasks at finalize/execute only (PQ-11). T100807 cancelled — superseded by WBS-1..7.\n\n# Locked decisions\nD-1..D-5 and PQ-6..PQ-12 recorded on plan v10+ and brainstorm session.\n\n# Tracking\nplan-artifact:08de149e-e528-4404-9e3a-885870fdf810","status":"planned","sortOrder":8,"linkedPlanArtifact":"plan-artifact:08de149e-e528-4404-9e3a-885870fdf810","previousPlanArtifacts":[],"createdAt":"2026-07-07T21:27:12.540Z","updatedAt":"2026-07-09T18:24:22.330Z"}}}
