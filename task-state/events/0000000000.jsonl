her for all 28 commands. Thin ideasModule and planningModule wrappers delegate for rollback only (not long-term independent disable). Prefer manifest-resolved instruction paths.","dependsOn":["T100862"],"technicalScope":["src/modules/planning/shared/dispatch.ts","src/modules/planning/index.ts","src/modules/ideas/index.ts","src/modules/index.ts","test/module-command-router.test.mjs"],"acceptanceCriteria":["All 28 commands route while both modules remain registered","No argv/schema/policy behavior changes","Shim documented as transitional rollback aid only","module-command-router / command smoke tests pass","Rollback path: re-enable ideas shell without handler rewrites"],"phase":"Phase 149","phaseKey":"149","metadata":{"planRef":"plan-artifact:cb3e2fbe-0883-492f-9f90-27fce166788f","planningProvenance":{"planId":"cb3e2fbe-0883-492f-9f90-27fce166788f","planVersion":17,"wbsId":"WBS-3","wbsPath":"3","planRef":"plan-artifact:cb3e2fbe-0883-492f-9f90-27fce166788f","planningType":"change","sourceIdeaId":"I006","source":"persist-planning-execution-drafts"}}}},"workspace":{"phaseKey":"149"},"expectedTaskVersion":1}
