{"schemaVersion":1,"eventId":"evt-a32b61b8-58b7-4302-a844-258895e46fda","sequence":2348,"parentEventId":"evt-af08f83f-3bb8-406c-ad26-a8d56ea8c265","recordedAt":"2026-07-02T05:40:35.548Z","actor":{"id":"workspace-kit","source":"system"},"command":{"name":"create-idea","moduleId":"ideas"},"kind":"planning.idea.created","payload":{"idea":{"id":"I006","title":"Merge Ideas and Planning modules","note":"Ideas and Planning modules have overlapping concerns now that the Planning module drives document status transitions (planning→reviewed→accepted) on the unified IdeaPlan document. A merged module would eliminate the cross-module import boundary and make the document lifecycle ownership fully explicit. The planning module also has generic commands (build-plan, execute-plan-artifact, list-planning-types) that are not idea-specific — those would need to stay separate or be reorganized. Scope and impact need evaluation before committing.","status":"open","sortOrder":5,"linkedPlanArtifact":null,"previousPlanArtifacts":[],"createdAt":"2026-07-02T05:40:35.548Z","updatedAt":"2026-07-02T05:40:35.548Z"}}}
