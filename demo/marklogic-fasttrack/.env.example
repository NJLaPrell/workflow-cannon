# Copy to .env and adjust before: docker compose up -d
#
# MarkLogic developer license: https://developer.marklogic.com/free-developer/
# Leave LICENSE fields empty to use the image evaluation license when available.

# MarkLogic container image (Progress official)
MARKLOGIC_IMAGE=progressofficial/marklogic-db:11.3.0

# Admin credentials (required for MARKLOGIC_INIT=true)
MARKLOGIC_ADMIN_USERNAME=admin
MARKLOGIC_ADMIN_PASSWORD=ChangeMe!MarkLogic1337
MARKLOGIC_WALLET_PASSWORD=
MARKLOGIC_REALM=public

# Optional explicit license (recommended for long-running demos)
MARKLOGIC_LICENSE_KEY=
MARKLOGIC_LICENSEE=

# Host port map
MARKLOGIC_PORT_MANAGE=8001
MARKLOGIC_PORT_APPSERVICES=8000
MARKLOGIC_PORT_REST=8002

# FastTrack UI placeholder (nginx until the React app is wired in later tasks)
FASTTRACK_IMAGE=nginx:1.27-alpine
FASTTRACK_PORT=3000
