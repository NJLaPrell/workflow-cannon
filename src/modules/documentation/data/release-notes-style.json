{
  "schemaVersion": 1,
  "audience": "end users, adopters, and operators — not implementers",
  "sourcePriority": [
    "metadata.releaseNoteSummary",
    "metadata.userFacingSummary",
    "acceptanceCriteria",
    "summary",
    "title"
  ],
  "excludeChangeKinds": ["chore"],
  "includeWhenMetadata": ["releaseNoteSummary", "userFacingSummary", "includeInReleaseNotes"],
  "internalKeywords": [
    "runtime",
    "schema",
    "sqlite",
    "projection",
    "hydration",
    "refactor",
    "manifest",
    "envelope",
    "idempotent",
    "middleware",
    "typescript",
    "eslint",
    "webpack",
    "migration command",
    "user_version",
    "blob store",
    "relational row",
    "dispatch",
    "router",
    "instruction contract",
    "view model",
    "renderer",
    "normalizer",
    "parser",
    "ajv",
    "semver",
    "workspace-kit.db"
  ],
  "stripPatterns": [
    "\\`[^`]*\\`",
    "\\b(?:src|docs|\\.ai|test|scripts)/[\\w./-]+",
    "\\b(?:pnpm|npm|yarn)\\s+(?:exec\\s+)?(?:run\\s+)?[\\w:-]+",
    "\\bworkspace-kit\\s+run\\s+[\\w-]+",
    "\\bwk\\s+(?:run|doctor)\\b",
    "\\bT\\d{3,}\\b",
    "\\bschema\\s+v?\\d+\\b",
    "\\bSQLite\\s+v?\\d+\\b",
    "\\b(?:alongside|via|using)\\s+the\\s+existing\\s+[^.,;]+",
    "\\([^)]*(?:module|command|schema|runtime|API)[^)]*\\)"
  ],
  "leadingVerbReplacements": [
    { "pattern": "^implement\\s+", "replacement": "" },
    { "pattern": "^add\\s+", "replacement": "" },
    { "pattern": "^wire\\s+(?:up\\s+)?", "replacement": "" },
    { "pattern": "^integrate\\s+", "replacement": "" },
    { "pattern": "^refactor\\s+", "replacement": "" },
    { "pattern": "^update\\s+", "replacement": "" },
    { "pattern": "^introduce\\s+", "replacement": "" }
  ],
  "phraseCleanup": [
    { "pattern": "\\bmulti-lease\\b", "replacement": "multiple concurrent" },
    { "pattern": "\\bcoalesced background hydration\\b", "replacement": "faster background updates" },
    { "pattern": "\\bterminal-row readout\\b", "replacement": "terminal view" },
    { "pattern": "\\bdashboard-summary\\b", "replacement": "dashboard overview" },
    { "pattern": "\\bactivity-slice\\b", "replacement": "activity feed" },
    { "pattern": "\\bpolling integration\\b", "replacement": "live refresh" },
    { "pattern": "\\btask enrichment\\b", "replacement": "richer task details" },
    { "pattern": "\\bstatus chips\\b", "replacement": "status badges" },
    { "pattern": "\\battention sorting\\b", "replacement": "priority sorting" }
  ],
  "technicalDensityThreshold": 0.22,
  "minPublicDescriptionLength": 12,
  "maxDescriptionLength": 160
}
