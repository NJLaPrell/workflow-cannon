{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workflow-cannon.dev/schemas/task-state-event.v1.json",
  "title": "Task state event (envelope + payload v1)",
  "description": "Canonical git-backed task-state event: shared envelope (S1.1) plus discriminated payload (S1.2). Includes planning event kinds (Phase 119/120).",
  "$ref": "#/$defs/fullEvent",
  "$defs": {
    "fullEvent": {
      "allOf": [
        { "$ref": "task-state-event-envelope.v1.json" },
        {
          "type": "object",
          "required": ["kind", "payload"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "task.created",
                "task.updated",
                "task.transitioned",
                "task.batch_applied",
                "planning.phase_catalog.upserted",
                "planning.phase_catalog.removed",
                "planning.workspace_status.updated",
                "planning.phase_note.created",
                "planning.phase_note.updated",
                "planning.phase_note.archived",
                "planning.phase_note_suggestion.created",
                "planning.phase_note_suggestion.updated",
                "planning.phase_note_suggestion.removed",
                "planning.idea.created",
                "planning.idea.updated",
                "planning.phase_delivery_history.upserted",
                "planning.module_state.updated"
              ]
            },
            "payload": {
              "oneOf": [
                { "$ref": "#/$defs/taskCreatedPayload" },
                { "$ref": "#/$defs/taskUpdatedPayload" },
                { "$ref": "#/$defs/taskTransitionedPayload" },
                { "$ref": "#/$defs/taskBatchAppliedPayload" },
                { "$ref": "#/$defs/planningPhaseCatalogUpsertedPayload" },
                { "$ref": "#/$defs/planningPhaseCatalogRemovedPayload" },
                { "$ref": "#/$defs/planningWorkspaceStatusUpdatedPayload" },
                { "$ref": "#/$defs/planningPhaseNotePayload" },
                { "$ref": "#/$defs/planningPhaseNoteSuggestionPayload" },
                { "$ref": "#/$defs/planningPhaseNoteSuggestionRemovedPayload" },
                { "$ref": "#/$defs/planningIdeaPayload" },
                { "$ref": "#/$defs/planningPhaseDeliveryHistoryPayload" },
                { "$ref": "#/$defs/planningModuleStateUpdatedPayload" }
              ]
            }
          }
        },
        {
          "propertyNames": {
            "enum": [
              "schemaVersion",
              "eventId",
              "sequence",
              "parentEventId",
              "recordedAt",
              "actor",
              "clientMutationId",
              "expectedTaskVersion",
              "expectedWorkspaceRevision",
              "command",
              "workspace",
              "kind",
              "payload"
            ]
          }
        }
      ]
    },
    "taskStatus": {
      "type": "string",
      "enum": [
        "research",
        "proposed",
        "ready",
        "in_progress",
        "awaiting_review",
        "awaiting_policy_approval",
        "awaiting_external_decision",
        "blocked",
        "completed",
        "cancelled"
      ]
    },
    "guardResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed", "guardName"],
      "properties": {
        "allowed": { "type": "boolean" },
        "guardName": { "type": "string", "minLength": 1, "maxLength": 64 },
        "reason": { "type": "string", "maxLength": 512 }
      }
    },
    "taskCreatedPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["taskId", "initialStatus", "title", "type"],
      "properties": {
        "taskId": { "type": "string", "pattern": "^T[0-9]+$" },
        "initialStatus": { "$ref": "#/$defs/taskStatus" },
        "title": { "type": "string", "minLength": 1, "maxLength": 512 },
        "type": { "type": "string", "minLength": 1, "maxLength": 64 }
      }
    },
    "taskUpdatedPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["taskId", "changedFields"],
      "properties": {
        "taskId": { "type": "string", "pattern": "^T[0-9]+$" },
        "changedFields": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": { "type": "string", "minLength": 1, "maxLength": 128 }
        },
        "payloadDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "values": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "taskTransitionedPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "taskId",
        "fromState",
        "toState",
        "action",
        "transitionId",
        "guardResults",
        "dependentsUnblocked"
      ],
      "properties": {
        "taskId": { "type": "string", "pattern": "^T[0-9]+$" },
        "fromState": { "$ref": "#/$defs/taskStatus" },
        "toState": { "$ref": "#/$defs/taskStatus" },
        "action": { "type": "string", "minLength": 1, "maxLength": 64 },
        "transitionId": { "type": "string", "minLength": 8, "maxLength": 128 },
        "guardResults": {
          "type": "array",
          "items": { "$ref": "#/$defs/guardResult" }
        },
        "dependentsUnblocked": {
          "type": "array",
          "items": { "type": "string", "pattern": "^T[0-9]+$" }
        },
        "payloadDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "taskBatchAppliedPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["appliedCount", "transitionIds", "taskIds"],
      "properties": {
        "batchId": { "type": "string", "minLength": 1, "maxLength": 128 },
        "appliedCount": { "type": "integer", "minimum": 0 },
        "transitionIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 8, "maxLength": 128 }
        },
        "taskIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^T[0-9]+$" }
        }
      }
    },
    "planningPhaseCatalogUpsertedPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phaseKey", "updatedAt"],
      "properties": {
        "phaseKey": { "type": "string", "minLength": 1, "maxLength": 32 },
        "shortDescription": { "type": ["string", "null"], "maxLength": 512 },
        "updatedAt": { "type": "string", "minLength": 20, "maxLength": 64 }
      }
    },
    "planningPhaseCatalogRemovedPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phaseKey"],
      "properties": {
        "phaseKey": { "type": "string", "minLength": 1, "maxLength": 32 }
      }
    },
    "planningWorkspaceStatusUpdatedPayload": {
      "type": "object",
      "required": ["patch", "after"],
      "additionalProperties": false,
      "properties": {
        "patch": { "type": "object", "additionalProperties": true },
        "after": { "type": "object", "additionalProperties": true },
        "payloadDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "previousCurrentKitPhase": { "type": ["string", "null"] }
      }
    },
    "planningPhaseNotePayload": {
      "type": "object",
      "required": ["note"],
      "additionalProperties": false,
      "properties": {
        "note": { "type": "object", "additionalProperties": true }
      }
    },
    "planningPhaseNoteSuggestionPayload": {
      "type": "object",
      "required": ["suggestion"],
      "additionalProperties": false,
      "properties": {
        "suggestion": { "type": "object", "additionalProperties": true }
      }
    },
    "planningPhaseNoteSuggestionRemovedPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["suggestionId", "noteId"],
      "properties": {
        "suggestionId": { "type": "string", "minLength": 1 },
        "noteId": { "type": "string", "minLength": 1 }
      }
    },
    "planningIdeaPayload": {
      "type": "object",
      "required": ["idea"],
      "additionalProperties": false,
      "properties": {
        "idea": { "type": "object", "additionalProperties": true },
        "removed": { "type": "boolean" }
      }
    },
    "planningPhaseDeliveryHistoryPayload": {
      "type": "object",
      "required": ["row"],
      "additionalProperties": false,
      "properties": {
        "row": { "type": "object", "additionalProperties": true }
      }
    },
    "planningModuleStateUpdatedPayload": {
      "type": "object",
      "required": ["moduleId", "stateSchemaVersion", "state", "updatedAt"],
      "additionalProperties": false,
      "properties": {
        "moduleId": { "type": "string", "minLength": 1, "maxLength": 64 },
        "stateSchemaVersion": { "type": "integer", "minimum": 0 },
        "state": { "type": "object", "additionalProperties": true },
        "updatedAt": { "type": "string", "minLength": 20, "maxLength": 64 },
        "expectedStateSchemaVersion": { "type": "integer", "minimum": 0 },
        "removed": { "type": "boolean" }
      }
    }
  }
}
