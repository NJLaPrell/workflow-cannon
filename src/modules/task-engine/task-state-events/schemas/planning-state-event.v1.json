{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workflow-cannon.dev/schemas/planning-state-event.v1.json",
  "title": "Planning state event (envelope + payload v1)",
  "description": "Canonical git-backed planning events sharing the task-state envelope (Phase 119 + Phase 120 S1 phase journal).",
  "$ref": "#/$defs/fullEvent",
  "$defs": {
    "fullEvent": {
      "allOf": [
        { "$ref": "task-state-event-envelope.v1.json" },
        {
          "type": "object",
          "required": ["kind", "payload"],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "planning.phase_catalog.upserted",
                "planning.phase_catalog.removed",
                "planning.workspace_status.updated",
                "planning.phase_note.created",
                "planning.phase_note.updated",
                "planning.phase_note.archived",
                "planning.phase_note_suggestion.created",
                "planning.phase_note_suggestion.updated",
                "planning.phase_note_suggestion.removed",
                "planning.idea.created",
                "planning.idea.updated"
              ]
            },
            "expectedWorkspaceRevision": {
              "type": "integer",
              "minimum": 0
            },
            "payload": {
              "oneOf": [
                { "$ref": "#/$defs/phaseCatalogUpsertedPayload" },
                { "$ref": "#/$defs/phaseCatalogRemovedPayload" },
                { "$ref": "#/$defs/workspaceStatusUpdatedPayload" },
                { "$ref": "#/$defs/phaseNoteSnapshotPayload" },
                { "$ref": "#/$defs/phaseNoteSuggestionSnapshotPayload" },
                { "$ref": "#/$defs/phaseNoteSuggestionRemovedPayload" },
                { "$ref": "#/$defs/ideaMutationPayload" }
              ]
            }
          }
        },
        {
          "propertyNames": {
            "enum": [
              "schemaVersion",
              "eventId",
              "sequence",
              "parentEventId",
              "recordedAt",
              "actor",
              "clientMutationId",
              "expectedTaskVersion",
              "expectedWorkspaceRevision",
              "command",
              "workspace",
              "kind",
              "payload"
            ]
          }
        }
      ]
    },
    "phaseNoteEventRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["refType", "refValue"],
      "properties": {
        "refType": { "type": "string", "minLength": 1, "maxLength": 64 },
        "refValue": { "type": "string", "minLength": 1, "maxLength": 512 }
      }
    },
    "phaseNoteSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "phaseKey",
        "phaseLabel",
        "taskId",
        "author",
        "authorKind",
        "sessionId",
        "sourceCommand",
        "planningGeneration",
        "policyTraceId",
        "noteType",
        "summary",
        "details",
        "status",
        "priority",
        "createdAt",
        "updatedAt",
        "expiresAt",
        "supersededBy",
        "convertedTaskId",
        "idempotencyKey",
        "refs"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 64 },
        "phaseKey": { "type": "string", "minLength": 1, "maxLength": 64 },
        "phaseLabel": { "type": ["string", "null"], "maxLength": 120 },
        "taskId": { "type": ["string", "null"], "maxLength": 32 },
        "author": { "type": ["string", "null"], "maxLength": 120 },
        "authorKind": { "type": ["string", "null"], "maxLength": 64 },
        "sessionId": { "type": ["string", "null"], "maxLength": 120 },
        "sourceCommand": { "type": ["string", "null"], "maxLength": 64 },
        "planningGeneration": { "type": ["integer", "null"] },
        "policyTraceId": { "type": ["string", "null"], "maxLength": 120 },
        "noteType": { "type": "string", "minLength": 1, "maxLength": 64 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 512 },
        "details": { "type": ["string", "null"], "maxLength": 8192 },
        "status": {
          "type": "string",
          "enum": ["active", "converted", "superseded", "dismissed", "expired"]
        },
        "priority": {
          "type": "string",
          "enum": ["low", "normal", "high", "critical"]
        },
        "createdAt": { "type": "string", "minLength": 20, "maxLength": 64 },
        "updatedAt": { "type": "string", "minLength": 20, "maxLength": 64 },
        "expiresAt": { "type": ["string", "null"], "maxLength": 64 },
        "supersededBy": { "type": ["string", "null"], "maxLength": 64 },
        "convertedTaskId": { "type": ["string", "null"], "maxLength": 32 },
        "idempotencyKey": { "type": ["string", "null"], "maxLength": 120 },
        "refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/phaseNoteEventRef" }
        }
      }
    },
    "phaseNoteSuggestionSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "noteId",
        "title",
        "description",
        "suggestedStatus",
        "suggestedPhaseKey",
        "suggestedPhaseLabel",
        "suggestedTaskType",
        "acceptanceCriteriaJson",
        "convertedTaskId",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 64 },
        "noteId": { "type": "string", "minLength": 1, "maxLength": 64 },
        "title": { "type": "string", "minLength": 1, "maxLength": 512 },
        "description": { "type": "string", "minLength": 1, "maxLength": 8192 },
        "suggestedStatus": { "type": "string", "minLength": 1, "maxLength": 32 },
        "suggestedPhaseKey": { "type": "string", "minLength": 1, "maxLength": 64 },
        "suggestedPhaseLabel": { "type": ["string", "null"], "maxLength": 120 },
        "suggestedTaskType": { "type": ["string", "null"], "maxLength": 64 },
        "acceptanceCriteriaJson": { "type": ["string", "null"], "maxLength": 8192 },
        "convertedTaskId": { "type": ["string", "null"], "maxLength": 32 },
        "createdAt": { "type": "string", "minLength": 20, "maxLength": 64 },
        "updatedAt": { "type": "string", "minLength": 20, "maxLength": 64 }
      }
    },
    "phaseNoteSnapshotPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["note"],
      "properties": {
        "note": { "$ref": "#/$defs/phaseNoteSnapshot" }
      }
    },
    "phaseNoteSuggestionSnapshotPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["suggestion"],
      "properties": {
        "suggestion": { "$ref": "#/$defs/phaseNoteSuggestionSnapshot" }
      }
    },
    "phaseNoteSuggestionRemovedPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["suggestionId", "noteId"],
      "properties": {
        "suggestionId": { "type": "string", "minLength": 1, "maxLength": 64 },
        "noteId": { "type": "string", "minLength": 1, "maxLength": 64 }
      }
    },
    "ideaSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "note",
        "status",
        "sortOrder",
        "linkedPlanArtifact",
        "previousPlanArtifacts",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^I[0-9]+$", "maxLength": 16 },
        "title": { "type": "string", "minLength": 1, "maxLength": 512 },
        "note": { "type": ["string", "null"], "maxLength": 8192 },
        "status": {
          "type": "string",
          "enum": ["open", "planning", "planned"]
        },
        "sortOrder": { "type": "integer", "minimum": 0 },
        "linkedPlanArtifact": { "type": ["string", "null"], "maxLength": 512 },
        "previousPlanArtifacts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 512 }
        },
        "createdAt": { "type": "string", "minLength": 20, "maxLength": 64 },
        "updatedAt": { "type": "string", "minLength": 20, "maxLength": 64 }
      }
    },
    "ideaMutationPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["idea"],
      "properties": {
        "idea": { "$ref": "#/$defs/ideaSnapshot" },
        "removed": { "type": "boolean" }
      }
    },
    "phaseCatalogUpsertedPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phaseKey", "shortDescription", "updatedAt"],
      "properties": {
        "phaseKey": { "type": "string", "minLength": 1, "maxLength": 64 },
        "shortDescription": { "type": ["string", "null"], "maxLength": 240 },
        "updatedAt": { "type": "string", "minLength": 20, "maxLength": 64 }
      }
    },
    "phaseCatalogRemovedPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phaseKey"],
      "properties": {
        "phaseKey": { "type": "string", "minLength": 1, "maxLength": 64 }
      }
    },
    "workspaceStatusUpdatedPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["patch", "after"],
      "properties": {
        "patch": {
          "type": "object",
          "additionalProperties": true
        },
        "after": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "workspaceRevision",
            "currentKitPhase",
            "nextKitPhase",
            "activeFocus",
            "lastUpdated",
            "blockers",
            "pendingDecisions",
            "nextAgentActions",
            "updatedAt"
          ],
          "properties": {
            "workspaceRevision": { "type": "integer", "minimum": 0 },
            "currentKitPhase": { "type": ["string", "null"], "maxLength": 64 },
            "nextKitPhase": { "type": ["string", "null"], "maxLength": 64 },
            "activeFocus": { "type": ["string", "null"], "maxLength": 512 },
            "lastUpdated": { "type": ["string", "null"], "maxLength": 64 },
            "blockers": { "type": "array", "items": { "type": "string" } },
            "pendingDecisions": { "type": "array", "items": { "type": "string" } },
            "nextAgentActions": { "type": "array", "items": { "type": "string" } },
            "updatedAt": { "type": "string", "minLength": 20, "maxLength": 64 }
          }
        },
        "payloadDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  }
}
