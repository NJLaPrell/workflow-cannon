node_modules/
dist/
# Local policy / secrets — copy `.env.example` to `.env` (not committed)
.env
.DS_Store
artifacts/
!fixtures/cae/workspace-artifacts/files/
!fixtures/cae/workspace-artifacts/files/**
# CAE program stubs live under tasks/cae/artifacts/ (not repo-root build artifacts)
!tasks/cae/artifacts/
!tasks/cae/artifacts/**
# Machine-local runtime stamp (regenerate: pnpm exec wk init)
.workspace-kit/runtime.json
# Dashboard read-service local process stamp (pid/port/log) — not shared across machines
.workspace-kit/dashboard-service/runtime.json
.workspace-kit/dashboard-service/service.pid
.workspace-kit/dashboard-service/service.log
# Task store: canonical history on branch workflow-cannon/task-state (git-event-log); local projection only
# Do not commit repo-root task-state/ (branch layout materialization or bootstrap scratch — use the git branch)
/task-state/
.workspace-kit/tasks/workspace-kit.db
.workspace-kit/tasks/task-state-events.jsonl
.workspace-kit/tasks/*.db.bak*
.workspace-kit/tasks/*.db-wal
.workspace-kit/tasks/*.db-shm
# Optional: omit policy traces from VCS (remove if you want traces committed)
.workspace-kit/policy/
.workspace-kit/config/
.workspace-kit/improvement/
.workspace-kit/lineage/
.workspace-kit/approvals/
.workspace-kit/planning/
.workspace-kit/backups/
# Extension-local dashboard caches (e.g. weekly sparkline counts)
.workflow-cannon/
agent-transcripts/
# Extension VSIX builds (publish via vsce / attach to release locally)
extensions/cursor-workflow-cannon/*.vsix
.workspace-kit/migration-backups/**/.workspace-kit/tasks/*.db
