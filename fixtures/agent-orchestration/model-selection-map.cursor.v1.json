  "scopeDimensions": [
    {
      "id": "complexity",
      "label": "Complexity",
      "weight": "high",
      "description": "Many modules, non-local reasoning, or large coordination surface.",
      "escalatesAt": "high"
    },
    {
      "id": "risk",
      "label": "Risk",
      "weight": "high",
      "description": "Data loss, security, release gates, or irreversible operations.",
      "escalatesAt": "high"
    },
    {
      "id": "ambiguity",
      "label": "Ambiguity",
      "weight": "high",
      "description": "Unclear acceptance criteria or conflicting specs.",
      "escalatesAt": "high"
    },
    {
      "id": "file_count",
      "label": "File count",
      "weight": "medium",
      "description": "Large owned-path touch surface.",
      "escalatesAt": "high"
    },
    {
      "id": "architecture_impact",
      "label": "Architecture impact",
      "weight": "high",
      "description": "Boundary moves, new stores, shared runtime, adapter parity.",
      "escalatesAt": "high"
    },
    {
      "id": "schema_migration_impact",
      "label": "Schema / migration impact",
      "weight": "critical",
      "description": "SQLite/task-store/schema migrations or contract version bumps.",
      "escalatesAt": "critical"
    },
    {
      "id": "test_difficulty",
      "label": "Test difficulty",
      "weight": "medium",
      "description": "Flaky CI, integration gaps, or parity harness work.",
      "escalatesAt": "high"
    },
    {
      "id": "policy_sensitivity",
      "label": "Policy sensitivity",
      "weight": "critical",
      "description": "Tier A/B commands, approval model, or audit/redaction behavior.",
      "escalatesAt": "critical"
    },
    {
      "id": "context_size",
      "label": "Context size",
      "weight": "medium",
      "description": "Large read slices or multi-artifact reconciliation.",
      "escalatesAt": "high"
    },
    {
      "id": "reasoning_depth",
      "label": "Reasoning depth",
      "weight": "high",
      "description": "Root-cause debugging or multi-hop planning.",
      "escalatesAt": "high"
    }
  ],
  "tierDefaults": {
    "cheap_fast": {
      "modelSlug": "composer-2.5-fast",
      "fallbackSlugs": ["composer-2.5"]
    },
    "balanced": {
      "modelSlug": "composer-2.5",
      "fallbackSlugs": ["claude-4.6-sonnet-medium-thinking"]
    },
    "high_reasoning": {
      "modelSlug": "gpt-5.3-codex",
      "fallbackSlugs": ["gpt-5.5-high"]
    },
    "specialist": {
      "modelSlug": "claude-opus-4-8-thinking-high",
      "fallbackSlugs": ["gpt-5.5-high"]
    }
  },
  "subagentTypeDefaults": {
    "explore": {
      "modelSlug": "composer-2.5-fast",
      "modelTier": "cheap_fast",
      "rationale": "Read-only codebase exploration should prefer the fastest capable model."
    },
    "shell": {
      "modelSlug": "composer-2.5-fast",
      "modelTier": "cheap_fast",
      "rationale": "Shell execution subagents are usually bounded command work."
    },
    "generalPurpose": {
      "modelSlug": "composer-2.5",
      "modelTier": "balanced",
      "rationale": "Default worker posture; escalate via scope signals when rules fire."
    },
    "cursor-guide": {
      "modelSlug": "composer-2.5-fast",
      "modelTier": "cheap_fast",
      "rationale": "Product doc lookup is read-heavy and narrow."
    },
    "ci-investigator": {
      "modelSlug": "claude-4.6-sonnet-medium-thinking",
      "modelTier": "balanced",
      "rationale": "CI failure summaries need moderate reasoning on bounded logs."
    },
    "bugbot": {
      "modelSlug": "claude-opus-4-8-thinking-high",
      "modelTier": "specialist",
      "rationale": "Review depth outweighs cost for PR defect finding."
    },
    "security-review": {
      "modelSlug": "claude-opus-4-8-thinking-high",
      "modelTier": "specialist",
      "rationale": "Security review is specialist-tier by default."
    },
    "best-of-n-runner": {
      "modelSlug": "composer-2.5",
      "modelTier": "balanced",
      "rationale": "Parallel attempts inherit worker default unless scope escalates."
    }
  },
  "selectionRules": [
    {
      "ruleId": "human_review_gate",
      "priority": 1000,
      "label": "Human review required",
      "match": {
        "anyAtOrAbove": {
          "policy_sensitivity": "critical",
          "schema_migration_impact": "critical",
          "risk": "critical"
        }
      },
      "outcome": {
        "modelSlug": null,
        "modelTier": "human_review",
        "rationale": "Critical policy, migration, or risk signals require human review before subagent dispatch."
      }
    },
    {
      "ruleId": "security_specialist",
      "priority": 900,
      "label": "Security-heavy implementation",
      "match": {
        "anyAtOrAbove": {
          "policy_sensitivity": "high",
          "risk": "high"
        },
        "taskTypeHints": ["security", "redaction", "prompt-injection", "audit"]
      },
      "outcome": {
        "modelSlug": "claude-4.6-sonnet-medium-thinking",
        "modelTier": "balanced",
        "rationale": "Security-adjacent implementation benefits from thinking-capable sonnet before opus spend.",
        "fallbackSlugs": ["claude-opus-4-8-thinking-high"]
      }
    },
    {
      "ruleId": "architecture_runtime_refactor",
      "priority": 800,
      "label": "Architecture / shared runtime",
      "match": {
        "anyAtOrAbove": {
          "architecture_impact": "high",
          "complexity": "high"
        },
        "taskTypeHints": ["runtime", "adapter", "shared-runtime", "cli-refactor", "mcp-refactor"]
      },
      "outcome": {
        "modelSlug": "gpt-5.3-codex",
        "modelTier": "high_reasoning",
        "rationale": "Cross-surface runtime and refactor work maps to the strongest code model tier.",
        "fallbackSlugs": ["gpt-5.5-high"]
      }
    },
    {
      "ruleId": "high_weight_escalation",
      "priority": 700,
      "label": "Multiple high-weight scope signals",
      "match": {
        "highWeightCountAtOrAbove": {
          "level": "high",
          "count": 2
        }
      },
      "outcome": {
        "modelSlug": "gpt-5.5-high",
        "modelTier": "high_reasoning",
        "rationale": "Two or more high-weight scope dimensions fired; use high-reasoning tier.",
        "fallbackSlugs": ["claude-opus-4-8-thinking-high"]
      }
    },
    {
      "ruleId": "narrow_mechanical",
      "priority": 600,
      "label": "Narrow mechanical scope",
      "match": {
        "allAtOrAbove": {
          "complexity": "low",
          "risk": "low",
          "ambiguity": "low"
        },
        "ownedPathCountAtLeast": 1,
        "taskTypeHints": ["docs", "fixtures", "formatting", "inventory", "delivery-loop"]
      },
      "outcome": {
        "modelSlug": "composer-2.5-fast",
        "modelTier": "cheap_fast",
        "rationale": "Low-risk, narrow scope fits the cheapest capable worker model."
      }
    },
    {
      "ruleId": "default_balanced_worker",
      "priority": 100,
      "label": "Default balanced worker",
      "match": {},
      "outcome": {
        "useTierDefault": true,
        "modelTier": "balanced",
        "rationale": "No escalation rules matched; use balanced tier default."
      }
    }
  ]
}
