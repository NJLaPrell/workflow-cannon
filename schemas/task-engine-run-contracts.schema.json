{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workflow-cannon.dev/schemas/task-engine-run-contracts.schema.json",
  "title": "Task Engine run command contracts",
  "description": "Versioned schema surface for task-engine `workspace-kit run` argument and response-data payloads.",
  "type": "object",
  "required": ["schemaVersion", "packageVersion", "moduleId", "commands"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "packageVersion": {
      "const": "0.64.1",
      "description": "Must match package.json version."
    },
    "moduleId": {
      "const": "task-engine"
    },
    "commands": {
      "type": "object",
      "required": [
        "run-transition",
        "create-task",
        "update-task",
        "update-wishlist",
        "update-workspace-phase-snapshot",
        "archive-task",
        "add-dependency",
        "agent-session-snapshot",
        "assign-task-phase",
        "backfill-task-feature-links",
        "backup-planning-sqlite",
        "remove-dependency",
        "get-dependency-graph",
        "get-kit-persistence-map",
        "get-task-history",
        "get-recent-task-activity",
        "get-task-summary",
        "get-blocked-summary",
        "create-task-from-plan",
        "clear-task-phase",
        "convert-wishlist",
        "create-wishlist",
        "get-wishlist",
        "get-task",
        "list-tasks",
        "list-wishlist",
        "get-ready-queue",
        "get-next-actions",
        "queue-git-alignment",
        "queue-health",
        "replay-queue-snapshot",
        "synthesize-transcript-churn",
        "explain-task-engine-model",
        "export-feature-taxonomy-json",
        "migrate-task-persistence",
        "dashboard-summary",
        "get-module-state",
        "list-components",
        "list-features",
        "list-module-states"
      ],
      "additionalProperties": false,
      "properties": {
        "run-transition": { "$ref": "#/$defs/contractRunTransition" },
        "create-task": { "$ref": "#/$defs/contractCreateTask" },
        "update-task": { "$ref": "#/$defs/contractUpdateTask" },
        "update-wishlist": { "$ref": "#/$defs/contractUpdateWishlist" },
        "update-workspace-phase-snapshot": { "$ref": "#/$defs/contractUpdateWorkspacePhaseSnapshot" },
        "archive-task": { "$ref": "#/$defs/contractArchiveTask" },
        "add-dependency": { "$ref": "#/$defs/contractDependencyMutation" },
        "agent-session-snapshot": { "$ref": "#/$defs/contractAgentSessionSnapshot" },
        "assign-task-phase": { "$ref": "#/$defs/contractAssignTaskPhase" },
        "backfill-task-feature-links": { "$ref": "#/$defs/contractBase" },
        "backup-planning-sqlite": { "$ref": "#/$defs/contractBackupPlanningSqlite" },
        "remove-dependency": { "$ref": "#/$defs/contractDependencyMutation" },
        "get-dependency-graph": { "$ref": "#/$defs/contractDependencyGraph" },
        "get-kit-persistence-map": { "$ref": "#/$defs/contractKitPersistenceMap" },
        "get-task-history": { "$ref": "#/$defs/contractTaskHistory" },
        "get-recent-task-activity": { "$ref": "#/$defs/contractRecentTaskActivity" },
        "get-task-summary": { "$ref": "#/$defs/contractTaskSummary" },
        "get-blocked-summary": { "$ref": "#/$defs/contractBlockedSummary" },
        "create-task-from-plan": { "$ref": "#/$defs/contractCreateTaskFromPlan" },
        "clear-task-phase": { "$ref": "#/$defs/contractClearTaskPhase" },
        "convert-wishlist": { "$ref": "#/$defs/contractConvertWishlist" },
        "create-wishlist": { "$ref": "#/$defs/contractCreateWishlist" },
        "get-wishlist": { "$ref": "#/$defs/contractGetWishlist" },
        "get-task": { "$ref": "#/$defs/contractGetTask" },
        "list-tasks": { "$ref": "#/$defs/contractListTasks" },
        "list-wishlist": { "$ref": "#/$defs/contractListWishlist" },
        "get-ready-queue": { "$ref": "#/$defs/contractReadyQueue" },
        "get-next-actions": { "$ref": "#/$defs/contractNextActions" },
        "queue-git-alignment": { "$ref": "#/$defs/contractBase" },
        "queue-health": { "$ref": "#/$defs/contractQueueHealth" },
        "replay-queue-snapshot": { "$ref": "#/$defs/contractBase" },
        "synthesize-transcript-churn": { "$ref": "#/$defs/contractSynthesizeTranscriptChurn" },
        "explain-task-engine-model": { "$ref": "#/$defs/contractExplainTaskEngineModel" },
        "export-feature-taxonomy-json": { "$ref": "#/$defs/contractBase" },
        "migrate-task-persistence": { "$ref": "#/$defs/contractMigrateTaskPersistence" },
        "dashboard-summary": { "$ref": "#/$defs/contractDashboardSummary" },
        "get-module-state": { "$ref": "#/$defs/contractGetModuleState" },
        "list-components": { "$ref": "#/$defs/contractBase" },
        "list-features": { "$ref": "#/$defs/contractListFeatures" },
        "list-module-states": { "$ref": "#/$defs/contractListModuleStates" }
      }
    }
  },
  "$defs": {
    "contractBase": {
      "type": "object",
      "required": ["args", "responseData"],
      "additionalProperties": false,
      "properties": {
        "args": {
          "type": "object"
        },
        "responseData": {
          "type": "object"
        }
      }
    },
    "contractRunTransition": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "required": ["taskId", "action"],
              "additionalProperties": true,
              "properties": {
                "taskId": {
                  "type": "string",
                  "pattern": "^(T[0-9]+|imp-[0-9a-f]{14})$"
                },
                "action": { "type": "string" },
                "policyApproval": { "type": "object" },
                "expectedPlanningGeneration": {
                  "oneOf": [
                    { "type": "integer", "minimum": 0 },
                    { "type": "string", "pattern": "^[0-9]+$" }
                  ]
                },
                "actor": { "type": "string" },
                "config": { "type": "object" }
              }
            },
            "responseData": {
              "type": "object",
              "required": ["task", "presentation"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractCreateTask": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "required": ["id", "title"],
              "additionalProperties": true,
              "properties": {
                "id": { "type": "string", "pattern": "^T[0-9]+$" },
                "title": { "type": "string" },
                "status": { "type": "string", "enum": ["proposed", "ready"] },
                "clientMutationId": { "type": "string", "minLength": 1 },
                "expectedPlanningGeneration": {
                  "oneOf": [
                    { "type": "integer", "minimum": 0 },
                    { "type": "string", "pattern": "^[0-9]+$" }
                  ]
                },
                "actor": { "type": "string" },
                "config": { "type": "object" }
              }
            },
            "responseData": {
              "type": "object",
              "required": ["task", "presentation"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractCreateTaskFromPlan": {
      "allOf": [
        { "$ref": "#/$defs/contractCreateTask" },
        {
          "properties": {
            "args": {
              "required": ["planRef"]
            }
          }
        }
      ]
    },
    "contractUpdateTask": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "required": ["taskId", "updates"],
              "additionalProperties": true,
              "properties": {
                "taskId": {
                  "type": "string",
                  "pattern": "^(T[0-9]+|imp-[0-9a-f]{14})$"
                },
                "updates": { "type": "object" },
                "clientMutationId": { "type": "string", "minLength": 1 },
                "expectedPlanningGeneration": {
                  "oneOf": [
                    { "type": "integer", "minimum": 0 },
                    { "type": "string", "pattern": "^[0-9]+$" }
                  ]
                },
                "actor": { "type": "string" },
                "config": { "type": "object" }
              }
            },
            "responseData": {
              "type": "object",
              "required": ["task", "presentation"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractArchiveTask": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "required": ["taskId"],
              "additionalProperties": true,
              "properties": {
                "taskId": { "type": "string", "pattern": "^T[0-9]+$" },
                "archiveReason": { "type": "string" }
              }
            },
            "responseData": {
              "type": "object",
              "required": ["task", "presentation"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractAssignTaskPhase": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "required": ["taskId", "phaseKey"],
              "additionalProperties": true,
              "properties": {
                "taskId": { "type": "string", "minLength": 1 },
                "phaseKey": { "type": "string", "minLength": 1 },
                "phase": { "type": "string" },
                "clientMutationId": { "type": "string", "minLength": 1 }
              }
            },
            "responseData": {
              "type": "object",
              "required": ["task"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractClearTaskPhase": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "required": ["taskId"],
              "additionalProperties": true,
              "properties": {
                "taskId": { "type": "string", "minLength": 1 },
                "clientMutationId": { "type": "string", "minLength": 1 }
              }
            },
            "responseData": {
              "type": "object",
              "required": ["task"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractDependencyMutation": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "required": ["taskId", "dependsOnTaskId"],
              "additionalProperties": false,
              "properties": {
                "taskId": { "type": "string", "pattern": "^T[0-9]+$" },
                "dependsOnTaskId": { "type": "string", "pattern": "^T[0-9]+$" }
              }
            },
            "responseData": {
              "type": "object",
              "required": ["task", "presentation"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractDependencyGraph": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "taskId": { "type": "string", "pattern": "^T[0-9]+$" }
              }
            },
            "responseData": {
              "type": "object",
              "required": ["nodes", "edges"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractTaskHistory": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "taskId": { "type": "string", "pattern": "^T[0-9]+$" },
                "limit": { "type": "number" }
              }
            },
            "responseData": {
              "type": "object",
              "required": ["taskId", "items", "count"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractRecentTaskActivity": {
      "allOf": [
        { "$ref": "#/$defs/contractTaskHistory" }
      ]
    },
    "contractTaskSummary": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "additionalProperties": false
            },
            "responseData": {
              "type": "object",
              "required": ["stateSummary", "totalActive", "scope"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractBlockedSummary": {
      "allOf": [
        { "$ref": "#/$defs/contractTaskSummary" }
      ]
    },
    "contractCreateWishlist": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "required": ["title", "problemStatement", "expectedOutcome", "impact", "constraints", "successSignals", "requestor", "evidenceRef"],
              "additionalProperties": true
            },
            "responseData": {
              "type": "object",
              "required": ["wishlist", "presentation"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractUpdateWishlist": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "required": ["wishlistId", "patch"],
              "additionalProperties": true
            },
            "responseData": {
              "type": "object",
              "required": ["wishlist", "presentation"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractUpdateWorkspacePhaseSnapshot": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "currentKitPhase": { "type": "string" },
                "nextKitPhase": { "type": ["string", "null"] },
                "dryRun": { "type": "boolean" }
              }
            },
            "responseData": {
              "type": "object",
              "required": ["fileRelativePath", "snapshotBefore", "snapshotAfter", "dryRun"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractGetWishlist": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "required": ["wishlistId"],
              "additionalProperties": false,
              "properties": {
                "wishlistId": { "type": "string", "pattern": "^(?:W|T)[0-9]+$" }
              }
            },
            "responseData": {
              "type": "object",
              "required": ["wishlist"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractConvertWishlist": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "required": ["decomposition", "tasks"],
              "additionalProperties": true
            },
            "responseData": {
              "type": "object",
              "required": ["wishlist", "createdTasks", "presentation"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractGetTask": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "required": ["taskId"],
              "additionalProperties": false,
              "properties": {
                "taskId": { "type": "string", "pattern": "^T[0-9]+$" },
                "historyLimit": { "type": "number" }
              }
            },
            "responseData": {
              "type": "object",
              "required": ["task", "recentTransitions", "allowedActions", "presentation"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractListTasks": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "status": { "type": "string" },
                "phase": { "type": "string" },
                "type": { "type": "string" },
                "category": { "type": "string" },
                "tags": {
                  "oneOf": [
                    { "type": "string" },
                    { "type": "array", "items": { "type": "string" } }
                  ]
                },
                "metadataFilters": {
                  "type": "object",
                  "patternProperties": {
                    "^[a-zA-Z0-9_-]+(?:\\.[a-zA-Z0-9_-]+)*$": {
                      "type": ["string", "number", "boolean", "null"]
                    }
                  },
                  "additionalProperties": false
                },
                "includeArchived": { "type": "boolean" },
                "phaseKey": { "type": "string" },
                "includeQueueHints": { "type": "boolean" },
                "confidenceTier": { "type": "string" },
                "blockedReasonCategory": { "type": "string" },
                "features": {
                  "oneOf": [
                    { "type": "string" },
                    { "type": "array", "items": { "type": "string" } }
                  ]
                },
                "featureId": { "type": "string" },
                "componentId": { "type": "string" },
                "queueNamespace": { "type": "string" }
              }
            },
            "responseData": {
              "type": "object",
              "required": ["tasks", "count", "scope"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractListFeatures": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "componentId": { "type": "string" },
                "actor": { "type": "string" },
                "config": { "type": "object" }
              }
            },
            "responseData": {
              "type": "object",
              "required": ["features", "count"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractListWishlist": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "status": { "type": "string" }
              }
            },
            "responseData": {
              "type": "object",
              "required": ["items", "count", "scope"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractReadyQueue": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "additionalProperties": false
            },
            "responseData": {
              "type": "object",
              "required": ["tasks", "count", "scope", "queueNamespace"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractNextActions": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "additionalProperties": false
            },
            "responseData": {
              "type": "object",
              "required": [
                "readyQueue",
                "suggestedNext",
                "stateSummary",
                "blockingAnalysis",
                "scope",
                "queueNamespace"
              ],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractAgentSessionSnapshot": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "additionalProperties": false
            },
            "responseData": {
              "type": "object",
              "required": ["schemaVersion", "refreshedAt"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractQueueHealth": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "additionalProperties": false
            },
            "responseData": {
              "type": "object",
              "required": ["schemaVersion", "scope", "canonicalPhase", "readyTaskSummaries", "summary"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractSynthesizeTranscriptChurn": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "required": ["taskId", "synthesis"],
              "additionalProperties": true,
              "properties": {
                "taskId": {
                  "type": "string",
                  "pattern": "^T[0-9]+$"
                },
                "synthesis": {
                  "type": "object"
                },
                "policyApproval": {
                  "type": "object"
                },
                "expectedPlanningGeneration": {
                  "oneOf": [
                    { "type": "integer", "minimum": 0 },
                    { "type": "string", "pattern": "^[0-9]+$" }
                  ]
                },
                "actor": { "type": "string" },
                "config": { "type": "object" }
              }
            },
            "responseData": {
              "type": "object",
              "required": ["task"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractExplainTaskEngineModel": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "additionalProperties": false
            },
            "responseData": {
              "type": "object",
              "required": ["modelVersion", "variants", "planningBoundary", "executionTaskLifecycle"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractKitPersistenceMap": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "additionalProperties": false
            },
            "responseData": {
              "type": "object",
              "required": ["schemaVersion", "unifiedSqliteRelativePath", "runtime"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractMigrateTaskPersistence": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "additionalProperties": true
            },
            "responseData": {
              "type": "object",
              "required": ["migration"],
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "contractDashboardSummary": {
      "allOf": [
        { "$ref": "#/$defs/contractBase" },
        {
          "properties": {
            "args": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "config": { "type": "object" },
                "actor": { "type": "string" }
              }
            },
            "responseData": {
              "type": "object",
              "required": [
                "schemaVersion",
                "taskStoreLastUpdated",
                "workspaceStatus",
                "planningSession",
                "stateSummary",
                "readyQueueTop",
                "readyQueueCount",
                "executionPlanningScope",
                "wishlist",
                "blockedSummary",
                "suggestedNext",
                "blockingAnalysis",
                "dependencyOverview",
                "agentGuidance",
                "teamExecution",
                "subagentRegistry"
              ],
              "additionalProperties": true,
              "properties": {
                "schemaVersion": {
                  "type": "integer",
                  "enum": [2, 3]
                },
                "teamExecution": {
                  "type": "object",
                  "required": [
                    "schemaVersion",
                    "available",
                    "totalCount",
                    "activeCount",
                    "byStatus",
                    "topActive"
                  ],
                  "additionalProperties": true,
                  "properties": {
                    "schemaVersion": { "const": 1 },
                    "available": { "type": "boolean" },
                    "totalCount": { "type": "integer", "minimum": 0 },
                    "activeCount": { "type": "integer", "minimum": 0 },
                    "byStatus": {
                      "type": "object",
                      "required": [
                        "assigned",
                        "submitted",
                        "blocked",
                        "reconciled",
                        "cancelled"
                      ],
                      "additionalProperties": true
                    },
                    "topActive": {
                      "type": "array",
                      "items": { "type": "object", "additionalProperties": true }
                    }
                  }
                },
                "subagentRegistry": {
                  "type": "object",
                  "required": [
                    "schemaVersion",
                    "available",
                    "definitionsCount",
