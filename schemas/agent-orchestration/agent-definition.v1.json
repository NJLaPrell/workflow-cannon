{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workflow-cannon.dev/schemas/agent-orchestration/agent-definition.v1.json",
  "title": "AgentDefinition v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agentDefinitionId",
    "displayName",
    "description",
    "role",
    "hostCompatibility",
    "requiredCapabilities",
    "optionalCapabilities",
    "allowedCommands",
    "accessProfileId",
    "contextProfileId",
    "modelProfileId",
    "handoffContractId",
    "activityContractId",
    "retired",
    "version"
  ],
  "properties": {
    "agentDefinitionId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "displayName": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "role": {
      "type": "string",
      "enum": ["orchestrator", "task_worker", "reviewer", "validator", "supervisor", "manual", "unknown"]
    },
    "hostCompatibility": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["cursor", "vscode", "cli", "codex", "mcp", "service", "manual", "unknown"]
      }
    },
    "requiredCapabilities": { "type": "array", "items": { "type": "string" } },
    "optionalCapabilities": { "type": "array", "items": { "type": "string" } },
    "allowedCommands": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "accessProfileId": { "type": "string", "minLength": 1 },
    "contextProfileId": { "type": "string", "minLength": 1 },
    "modelProfileId": { "type": "string", "minLength": 1 },
    "handoffContractId": { "type": "string", "minLength": 1 },
    "activityContractId": { "type": "string", "minLength": 1 },
    "metadata": { "type": "object", "additionalProperties": true },
    "retired": { "type": "boolean" },
    "version": { "const": 1 }
  }
}
