{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workflow-cannon.dev/schemas/ideas/states/reviewed.schema.json",
  "title": "IdeaPlan reviewed state",
  "description": "Unified IdeaPlan document shape and agent contract when status is reviewed. Rubric review is recorded in the review section; the agent presents review results and may return to planning for revision or advance to acceptance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "planId",
    "version",
    "planRef",
    "status",
    "ideaId",
    "createdAt",
    "updatedAt",
    "brainstorm",
    "plan",
    "review",
    "agentDirective"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "planId": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "planRef": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "const": "reviewed"
    },
    "ideaId": {
      "type": "string",
      "pattern": "^I[0-9]+$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "brainstorm": {
      "$ref": "#/$defs/brainstormSection"
    },
    "plan": {
      "$ref": "#/$defs/planSection"
    },
    "review": {
      "$ref": "#/$defs/reviewSection"
    },
    "agentDirective": {
      "$ref": "#/$defs/agentDirective"
    },
    "acceptance": false,
    "delivery": false
  },
  "x-validTransitions": [
    "reviewed",
    "planning",
    "accepted",
    "cancelled"
  ],
  "x-canonicalAgentDirective": {
    "$ref": "#/$defs/canonicalAgentDirective"
  },
  "$defs": {
    "brainstormSession": {
      "$ref": "https://workflow-cannon.dev/schemas/ideas/brainstorm-session.schema.json"
    },
    "brainstormSection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sessions"
      ],
      "properties": {
        "sessions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/brainstormSession"
          }
        },
        "activeSessionId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "planSection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "summary"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "planningType": {
          "type": "string",
          "minLength": 1
        },
        "wbsRowCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "reviewSection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passed",
        "reviewedAt"
      ],
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "blockerCount": {
          "type": "integer",
          "minimum": 0
        },
        "openQuestionCount": {
          "type": "integer",
          "minimum": 0
        },
        "warningCount": {
          "type": "integer",
          "minimum": 0
        },
        "reviewedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "agentDirectiveQuestion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase",
        "fieldName",
        "prompt",
        "type"
      ],
      "properties": {
        "phase": {
          "type": "string",
          "enum": [
            "context",
            "session-notes"
          ]
        },
        "fieldName": {
          "type": "string",
          "minLength": 1
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "text",
            "enum"
          ]
        },
        "validValues": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "guidance": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "agentDirective": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "state",
        "questions"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "state": {
          "const": "reviewed"
        },
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/agentDirectiveQuestion"
          }
        }
      }
    },
    "canonicalAgentDirective": {
      "schemaVersion": 1,
      "state": "reviewed",
      "questions": [
        {
          "phase": "context",
          "fieldName": "reviewOutcome",
          "prompt": "Present the rubric review outcome to the operator.",
          "type": "text",
          "guidance": "Summarize review.passed, blockerCount, openQuestionCount, and warningCount from the review section."
        },
        {
          "phase": "context",
          "fieldName": "blockerSummary",
          "prompt": "List any blockers that prevent acceptance.",
          "type": "text",
          "guidance": "Blockers require returning to planning for revision. Warnings alone do not block acceptance."
        },
        {
          "phase": "session-notes",
          "fieldName": "nextStep",
          "prompt": "Should the operator revise the plan or proceed to acceptance?",
          "type": "enum",
          "validValues": [
            "revise-planning",
            "proceed-to-acceptance"
          ],
          "guidance": "Transition to planning when revision is needed; transition to accepted only when review.passed is true and blockers are resolved."
        }
      ]
    }
  }
}
