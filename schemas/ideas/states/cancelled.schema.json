{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workflow-cannon.dev/schemas/ideas/states/cancelled.schema.json",
  "title": "IdeaPlan cancelled state",
  "description": "Unified IdeaPlan document when status is cancelled. Soft-archived; may revive to brainstorming or planning. Progressive sections from prior states are optional.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "planId",
    "version",
    "planRef",
    "status",
    "ideaId",
    "createdAt",
    "updatedAt",
    "agentDirective"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "planId": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "planRef": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "const": "cancelled"
    },
    "ideaId": {
      "type": "string",
      "pattern": "^I[0-9]+$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "agentDirective": {
      "$ref": "#/$defs/agentDirective"
    },
    "cancellation": {
      "$ref": "#/$defs/cancellationSection"
    },
    "brainstorm": {
      "type": "object"
    },
    "plan": {
      "type": "object"
    },
    "review": {
      "type": "object"
    },
    "acceptance": {
      "type": "object"
    },
    "delivery": {
      "type": "object"
    }
  },
  "x-validTransitions": [
    "cancelled",
    "brainstorming",
    "planning"
  ],
  "x-canonicalAgentDirective": {
    "$ref": "#/$defs/canonicalAgentDirective"
  },
  "$defs": {
    "cancellationSection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cancelledAt",
        "previousStatus"
      ],
      "properties": {
        "cancelledAt": {
          "type": "string",
          "format": "date-time"
        },
        "previousStatus": {
          "type": "string",
          "enum": [
            "idea",
            "brainstorming",
            "planning",
            "reviewed",
            "accepted",
            "delivered",
            "cancelled"
          ]
        },
        "cancelledBy": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "agentDirectiveQuestion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase",
        "fieldName",
        "prompt",
        "type"
      ],
      "properties": {
        "phase": {
          "type": "string",
          "enum": [
            "context",
            "session-notes"
          ]
        },
        "fieldName": {
          "type": "string",
          "minLength": 1
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "text",
            "enum"
          ]
        },
        "validValues": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "guidance": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "agentDirective": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "state",
        "questions"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "state": {
          "const": "cancelled"
        },
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/agentDirectiveQuestion"
          }
        }
      }
    },
    "canonicalAgentDirective": {
      "schemaVersion": 1,
      "state": "cancelled",
      "questions": [
        {
          "phase": "session-notes",
          "fieldName": "reviveIntent",
          "prompt": "Should this cancelled plan be revived via Brainstorm or Plan?",
          "type": "enum",
          "validValues": [
            "brainstorm",
            "plan",
            "leave-cancelled"
          ],
          "guidance": "Brainstorm returns to ideation; Plan resumes structured planning on this same document."
        }
      ]
    }
  }
}
