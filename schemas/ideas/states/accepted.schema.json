{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workflow-cannon.dev/schemas/ideas/states/accepted.schema.json",
  "title": "IdeaPlan accepted state",
  "description": "Unified IdeaPlan document shape and agent contract when status is accepted. The operator approved the reviewed plan version; the acceptance record is required before delivery handoff.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "planId",
    "version",
    "planRef",
    "status",
    "ideaId",
    "createdAt",
    "updatedAt",
    "brainstorm",
    "plan",
    "review",
    "acceptance",
    "agentDirective"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "planId": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "planRef": { "type": "string", "minLength": 1 },
    "status": { "const": "accepted" },
    "ideaId": { "type": "string", "pattern": "^I[0-9]+$" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "brainstorm": { "$ref": "#/$defs/brainstormSection" },
    "plan": { "$ref": "#/$defs/planSection" },
    "review": { "$ref": "#/$defs/reviewSection" },
    "acceptance": { "$ref": "#/$defs/acceptanceSection" },
    "agentDirective": { "$ref": "#/$defs/agentDirective" },
    "delivery": false
  },
  "x-validTransitions": ["accepted", "delivered"],
  "x-canonicalAgentDirective": { "$ref": "#/$defs/canonicalAgentDirective" },
  "$defs": {
    "brainstormSession": {
      "$ref": "https://workflow-cannon.dev/schemas/ideas/brainstorm-session.schema.json"
    },
    "brainstormSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sessions"],
      "properties": {
        "sessions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/brainstormSession" }
        },
        "activeSessionId": { "type": "string", "minLength": 1 }
      }
    },
    "planSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "summary"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "planningType": { "type": "string", "minLength": 1 },
        "wbsRowCount": { "type": "integer", "minimum": 0 }
      }
    },
    "reviewSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "reviewedAt"],
      "properties": {
        "passed": { "type": "boolean" },
        "blockerCount": { "type": "integer", "minimum": 0 },
        "openQuestionCount": { "type": "integer", "minimum": 0 },
        "warningCount": { "type": "integer", "minimum": 0 },
        "reviewedAt": { "type": "string", "format": "date-time" }
      }
    },
    "acceptanceSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["acceptedAt", "acceptedBy", "acceptedVersion"],
      "properties": {
        "acceptedAt": { "type": "string", "format": "date-time" },
        "acceptedBy": { "type": "string", "minLength": 1 },
        "acceptedVersion": { "type": "integer", "minimum": 1 }
      }
    },
    "agentDirectiveQuestion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "fieldName", "prompt", "type"],
      "properties": {
        "phase": {
          "type": "string",
          "enum": ["context", "session-notes"]
        },
        "fieldName": { "type": "string", "minLength": 1 },
        "prompt": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "enum": ["text"] },
        "guidance": { "type": "string", "minLength": 1 }
      }
    },
    "agentDirective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "state", "questions"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "state": { "const": "accepted" },
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/agentDirectiveQuestion" }
        }
      }
    },
    "canonicalAgentDirective": {
      "schemaVersion": 1,
      "state": "accepted",
      "questions": [
        {
          "phase": "context",
          "fieldName": "acceptanceConfirmation",
          "prompt": "Confirm the acceptance record pins the reviewed plan version.",
          "type": "text",
          "guidance": "Present acceptance.acceptedAt, acceptance.acceptedBy, and acceptance.acceptedVersion. The accepted version must match the current document version."
        },
        {
          "phase": "context",
          "fieldName": "linkedPlanPromotion",
          "prompt": "Has the accepted plan been promoted to linkedPlanArtifact on the source idea?",
          "type": "text",
          "guidance": "Acceptance is durable only when the plan-artifact version is pinned and the ideas row linked_plan_artifact pointer is updated per ADR."
        },
        {
          "phase": "session-notes",
          "fieldName": "deliveryReadiness",
          "prompt": "Is the plan ready for delivery handoff (task materialization)?",
          "type": "text",
          "guidance": "Transition to delivered after execution linkage and delivery metadata are recorded."
        }
      ]
    }
  }
}
