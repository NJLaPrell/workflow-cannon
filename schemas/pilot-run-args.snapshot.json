      "properties": {
        "taskId": {
          "type": "string",
          "pattern": "^T[0-9]+$"
        },
        "dependsOnTaskId": {
          "type": "string",
          "pattern": "^T[0-9]+$"
        }
      },
      "additionalProperties": false
