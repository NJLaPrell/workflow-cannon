        "id",
        "title"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^T[0-9]+$"
        },
        "title": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "proposed",
            "ready"
          ]
        },
        "clientMutationId": {
          "type": "string",
          "minLength": 1
        },
        "expectedPlanningGeneration": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "string",
              "pattern": "^[0-9]+$"
            }
          ]
        },
        "actor": {
          "type": "string"
        },
        "config": {
          "type": "object"
        }
