{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workflow-cannon.dev/schemas/cae/cli-read-only-data.v1.json",
  "title": "CAE read-only CLI success `data` payloads (v1)",
  "description": "Shape of `data` when `ok: true` (T847). Outer envelope `{ ok, code, message?, data }` is kit-standard; these defs validate `data` only.",
  "$defs": {
    "caeListArtifactsData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "artifactIds"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "artifactIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3,
            "maxLength": 128,
            "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
          },
          "maxItems": 200
        },
        "nextCursor": {
          "type": ["string", "null"],
          "maxLength": 256
        }
      }
    },
    "caeGetArtifactData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "artifact"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "artifact": {
          "$ref": "https://workflow-cannon.dev/schemas/cae/registry-entry.v1.json"
        }
      }
    },
    "caeListActivationsData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "activationIds"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "activationIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3,
            "maxLength": 128,
            "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$"
          },
          "maxItems": 200
        },
        "nextCursor": {
          "type": ["string", "null"],
          "maxLength": 256
        }
      }
    },
    "caeGetActivationData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "activation"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "activation": {
          "$ref": "https://workflow-cannon.dev/schemas/cae/activation-definition.schema.json"
        }
      }
    },
    "caeEvaluateData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "bundle", "trace", "traceId"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "traceId": {
          "type": "string",
          "minLength": 8,
          "maxLength": 128
        },
        "bundle": {
          "$ref": "https://workflow-cannon.dev/schemas/cae/effective-activation-bundle.v1.json"
        },
        "trace": {
          "$ref": "https://workflow-cannon.dev/schemas/cae/trace.v1.json"
        },
        "ephemeral": {
          "type": "boolean",
          "description": "When true, trace is session/ephemeral only (pre-T867 persistence)."
        }
      }
    },
    "caeExplainData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "explanation"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "explanation": {
          "$ref": "https://workflow-cannon.dev/schemas/cae/explain-response.v1.json"
        },
        "trace": {
          "$ref": "https://workflow-cannon.dev/schemas/cae/trace.v1.json",
          "description": "Present when explain used replay path or engine echoes source trace."
        },
        "storage": {
          "type": "string",
          "enum": ["memory", "sqlite"]
        },
        "ephemeral": {
          "type": "boolean"
        }
      }
    },
    "caeHealthData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "caeEnabled", "registryStatus", "issues"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "caeEnabled": {
          "type": "boolean",
          "description": "Effective `kit.cae.enabled` after config resolution."
        },
        "persistenceEnabled": {
          "type": "boolean"
        },
        "lastEvalAt": {
          "type": ["string", "null"],
          "maxLength": 40
        },
        "lastEvalAtNote": {
          "type": "string",
          "maxLength": 256
        },
        "registryStore": {
          "type": "string",
          "enum": ["json", "sqlite"]
        },
        "registryStatus": {
          "type": "string",
          "enum": ["absent", "loading", "ok", "invalid"]
        },
        "registryContentHash": {
          "type": "string",
          "maxLength": 128,
          "description": "Optional fingerprint of loaded registry snapshot."
        },
        "artifactCount": {
          "type": "integer",
          "minimum": 0
        },
        "activationCount": {
          "type": "integer",
          "minimum": 0
        },
        "activeRegistryVersionId": {
          "type": "string",
          "maxLength": 128
        },
        "traceRowCount": {
          "type": "integer",
          "minimum": 0
        },
        "ackRowCount": {
          "type": "integer",
          "minimum": 0
        },
        "lastSuccessfulEvalAt": {
          "type": "string",
          "maxLength": 40,
          "description": "ISO-ish timestamp of last successful evaluate (T862); nullable semantics via omission."
        },
        "issues": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code"],
            "properties": {
              "code": { "type": "string", "maxLength": 64 },
              "detail": { "type": "string", "maxLength": 512 }
            }
          }
        }
      }
    },
    "caeGuidanceFamilyCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy", "think", "do", "review"],
      "properties": {
        "policy": { "type": "integer", "minimum": 0 },
        "think": { "type": "integer", "minimum": 0 },
        "do": { "type": "integer", "minimum": 0 },
        "review": { "type": "integer", "minimum": 0 }
      }
    },
    "caeGuidanceProductLabels": {
      "type": "object",
      "additionalProperties": true,
      "required": ["productName", "technicalName", "terms", "families"],
      "properties": {
        "productName": { "type": "string", "maxLength": 64 },
        "technicalName": { "type": "string", "maxLength": 128 },
        "terms": { "type": "object", "additionalProperties": { "type": "string" } },
        "families": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "caeGuidanceMutationHintsV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canClone", "canActivate", "canEditDraft", "canRetire", "denialReason"],
      "properties": {
        "canClone": { "type": "boolean" },
        "canActivate": { "type": "boolean" },
        "canEditDraft": { "type": "boolean" },
        "canRetire": { "type": "boolean" },
        "denialReason": { "type": ["string", "null"] }
      }
    },
    "caeGuidanceRuleCatalogItemV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "ordinal",
        "family",
        "familyLabel",
        "displayTitle",
        "appliesWhen",
        "lifecycleState",
        "lifecycleLabel",
        "priority",
        "attention",
        "sources",
        "mutation",
        "debug"
      ],
      "properties": {
        "schemaVersion": { "const": 1 },
        "ordinal": { "type": "integer", "minimum": 1 },
        "family": {
          "type": "string",
          "enum": ["policy", "think", "do", "review"]
        },
        "familyLabel": { "type": "string", "maxLength": 128 },
        "displayTitle": { "type": "string", "maxLength": 512 },
        "appliesWhen": { "type": "string", "maxLength": 4096 },
        "lifecycleState": {
          "type": "string",
          "enum": ["draft", "active", "retired", "disabled"]
        },
        "lifecycleLabel": { "type": "string", "maxLength": 64 },
        "priority": { "type": "number" },
        "attention": {
          "type": "string",
          "enum": ["required", "check", "advisory"]
        },
        "acknowledgementStrength": { "type": ["string", "null"], "maxLength": 64 },
        "acknowledgementTokenPresent": { "type": "boolean" },
        "sources": {
          "type": "array",
          "maxItems": 16,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title"],
            "properties": {
              "title": { "type": "string", "maxLength": 512 }
            }
          }
        },
        "mutation": {
          "$ref": "#/$defs/caeGuidanceMutationHintsV1"
        },
        "debug": {
          "type": "object",
          "additionalProperties": false,
          "required": ["activationId", "artifactIds"],
          "properties": {
            "activationId": { "type": "string", "maxLength": 256 },
            "artifactIds": {
              "type": "array",
              "maxItems": 64,
              "items": { "type": "string", "maxLength": 256 }
            }
          }
        }
      }
    },
    "caeGuidanceRulesCatalogV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "registrySnapshotTag", "itemCount", "items"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "registrySnapshotTag": { "type": ["string", "null"], "maxLength": 256 },
        "itemCount": { "type": "integer", "minimum": 0 },
        "degraded": { "type": "boolean" },
        "degradedCode": { "type": "string", "maxLength": 128 },
        "degradedMessage": { "type": ["string", "null"], "maxLength": 2048 },
        "items": {
          "type": "array",
          "maxItems": 500,
          "items": { "$ref": "#/$defs/caeGuidanceRuleCatalogItemV1" }
        }
      }
    },
    "caeGuidanceProductDashboardEnvelope": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schemaVersion", "rulesCatalog"],
      "properties": {
        "schemaVersion": { "type": "integer", "const": 1 },
        "rulesCatalog": { "$ref": "#/$defs/caeGuidanceRulesCatalogV1" }
      }
    },
    "caeRecentTraceSummaryRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "traceId",
        "createdAt",
        "storage",
        "evalMode",
        "familyCounts",
        "totalGuidanceCount",
        "pendingAcknowledgementCount",
        "conflictCount",
        "bundleId"
      ],
      "properties": {
        "traceId": { "type": "string", "minLength": 8, "maxLength": 128 },
        "createdAt": { "type": "string", "maxLength": 40 },
        "storage": { "type": "string", "enum": ["sqlite"] },
        "evalMode": { "type": "string", "enum": ["live", "shadow"] },
        "familyCounts": { "$ref": "#/$defs/caeGuidanceFamilyCounts" },
        "totalGuidanceCount": { "type": "integer", "minimum": 0 },
        "pendingAcknowledgementCount": { "type": "integer", "minimum": 0 },
        "conflictCount": { "type": "integer", "minimum": 0 },
        "bundleId": { "type": ["string", "null"], "maxLength": 128 },
        "taskId": { "type": "string", "minLength": 3, "maxLength": 128 },
        "taskTitle": { "type": "string", "maxLength": 512 },
        "commandName": { "type": "string", "maxLength": 128 }
      }
    },
    "caeGuidanceCard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "activationId",
        "family",
        "familyLabel",
        "title",
        "attention",
        "artifactIds",
        "sourceTitles",
        "priority",
        "aggregateTightness"
      ],
      "properties": {
        "activationId": { "type": "string", "minLength": 3, "maxLength": 128 },
        "family": { "type": "string", "enum": ["policy", "think", "do", "review"] },
        "familyLabel": { "type": "string", "maxLength": 64 },
        "title": { "type": "string", "maxLength": 256 },
        "attention": { "type": "string", "enum": ["required", "check", "advisory"] },
        "artifactIds": {
          "type": "array",
          "maxItems": 64,
          "items": { "type": "string", "maxLength": 128 }
        },
        "sourceTitles": {
          "type": "array",
          "maxItems": 5,
          "items": { "type": "string", "maxLength": 256 }
        },
        "priority": { "type": "integer" },
        "aggregateTightness": { "type": "integer" }
      }
    },
    "caeRecentTracesData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "rows", "count", "storage", "retention"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "count": { "type": "integer", "minimum": 0 },
        "storage": { "type": "string", "enum": ["sqlite"] },
        "rows": {
          "type": "array",
          "maxItems": 200,
          "items": { "$ref": "#/$defs/caeRecentTraceSummaryRow" }
        },
        "retention": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxRows", "note"],
          "properties": {
            "maxRows": { "type": "integer", "minimum": 1 },
            "note": { "type": "string", "maxLength": 256 }
          }
        }
      }
    },
    "caeGuidancePreviewData": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "product",
        "evalMode",
        "modeLabel",
        "traceId",
        "ephemeral",
        "evaluationContext",
        "bundle",
        "trace",
        "guidanceCards",
        "familyCounts",
        "totalGuidanceCount",
        "pendingAcknowledgements",
        "conflictShadowSummary"
      ],
      "properties": {
        "schemaVersion": { "const": 1 },
        "product": { "$ref": "#/$defs/caeGuidanceProductLabels" },
        "evalMode": { "type": "string", "enum": ["live", "shadow"] },
        "modeLabel": { "type": "string", "maxLength": 64 },
        "traceId": { "type": "string", "minLength": 8, "maxLength": 128 },
        "ephemeral": { "type": "boolean" },
        "evaluationContext": {
          "$ref": "https://workflow-cannon.dev/schemas/cae/evaluation-context.v1.json"
        },
        "bundle": {
          "$ref": "https://workflow-cannon.dev/schemas/cae/effective-activation-bundle.v1.json"
        },
        "trace": { "$ref": "https://workflow-cannon.dev/schemas/cae/trace.v1.json" },
        "guidanceCards": {
          "type": "object",
          "additionalProperties": false,
          "required": ["policy", "think", "do", "review"],
          "properties": {
            "policy": { "type": "array", "items": { "$ref": "#/$defs/caeGuidanceCard" } },
            "think": { "type": "array", "items": { "$ref": "#/$defs/caeGuidanceCard" } },
            "do": { "type": "array", "items": { "$ref": "#/$defs/caeGuidanceCard" } },
            "review": { "type": "array", "items": { "$ref": "#/$defs/caeGuidanceCard" } }
          }
        },
        "familyCounts": { "$ref": "#/$defs/caeGuidanceFamilyCounts" },
        "totalGuidanceCount": { "type": "integer", "minimum": 0 },
        "pendingAcknowledgements": {
          "type": "array",
          "items": {
            "$ref": "https://workflow-cannon.dev/schemas/cae/effective-activation-bundle.v1.json#/$defs/pendingAcknowledgementItem"
          }
        },
        "conflictShadowSummary": {
          "$ref": "https://workflow-cannon.dev/schemas/cae/effective-activation-bundle.v1.json#/$defs/conflictShadowSummary"
        },
        "draftImpact": {
          "type": "object",
          "additionalProperties": true,
          "description": "Synthetic draft Guidance impact matrix (baseline vs overlay) when `draftRule` was supplied."
        }
      }
    },
    "caeDashboardSummaryData": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "product",
        "guidanceProduct",
        "health",
        "validation",
        "recentTraces",
        "acknowledgements",
        "feedback"
      ],
      "properties": {
        "schemaVersion": { "const": 1 },
        "product": { "$ref": "#/$defs/caeGuidanceProductLabels" },
        "guidanceProduct": { "$ref": "#/$defs/caeGuidanceProductDashboardEnvelope" },
        "health": { "$ref": "#/$defs/caeHealthData" },
        "validation": {
          "type": "object",
          "additionalProperties": true,
          "required": ["ok", "code"],
          "properties": {
            "ok": { "type": "boolean" },
            "code": { "type": "string", "maxLength": 128 }
          }
        },
        "recentTraces": {
          "type": "object",
          "additionalProperties": true,
          "required": ["available", "rows", "count"],
          "properties": {
            "available": { "type": "boolean" },
            "count": { "type": "integer", "minimum": 0 },
            "rows": {
              "type": "array",
              "maxItems": 200,
              "items": { "$ref": "#/$defs/caeRecentTraceSummaryRow" }
            }
          }
        },
        "acknowledgements": {
          "type": "object",
          "additionalProperties": true,
          "required": ["available", "count", "rows"],
          "properties": {
            "available": { "type": "boolean" },
            "count": { "type": "integer", "minimum": 0 },
            "rows": { "type": "array", "maxItems": 200 }
          }
        },
        "feedback": {
          "type": "object",
          "additionalProperties": true,
          "required": ["available", "summary", "rows"],
          "properties": {
            "available": { "type": "boolean" },
            "summary": { "type": "object" },
            "rows": { "type": "array", "maxItems": 200 }
          }
        }
      }
    },
    "caeConflictsData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "conflictShadowSummary", "traceId"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "traceId": {
          "type": "string",
          "minLength": 8,
          "maxLength": 128,
          "description": "Synthetic or evaluation trace used for the conflict pass."
        },
        "conflictShadowSummary": {
          "$ref": "https://workflow-cannon.dev/schemas/cae/effective-activation-bundle.v1.json#/$defs/conflictShadowSummary"
        }
      }
    },
    "caeGetTraceData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "trace"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "trace": {
          "$ref": "https://workflow-cannon.dev/schemas/cae/trace.v1.json"
        },
        "ephemeral": {
          "type": "boolean",
          "description": "True when trace is not loaded from durable store."
        },
        "storage": {
          "type": "string",
          "enum": ["memory", "sqlite"]
        }
      }
    },
    "caeListAcksData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "rows", "count"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "count": { "type": "integer", "minimum": 0 },
        "filters": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "traceId": { "type": ["string", "null"], "maxLength": 128 },
            "activationId": { "type": ["string", "null"], "maxLength": 128 }
          }
        },
        "rows": {
          "type": "array",
          "maxItems": 200,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "traceId", "ackToken", "activationId", "satisfiedAt", "actor"],
            "properties": {
              "id": { "type": "integer", "minimum": 1 },
              "traceId": { "type": "string", "minLength": 8, "maxLength": 128 },
              "ackToken": { "type": "string", "minLength": 1, "maxLength": 128 },
              "activationId": { "type": "string", "minLength": 3, "maxLength": 128 },
              "satisfiedAt": { "type": "string", "maxLength": 40 },
              "actor": { "type": "string", "minLength": 1, "maxLength": 256 }
            }
          }
        }
      }
    }
  }
}
