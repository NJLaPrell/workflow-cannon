{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workflow-cannon.dev/schemas/task-sync-flush-result.v1.json",
  "title": "Task sync flush result v1",
  "description": "Outbox drain attempt result from POST /task-sync/flush.",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "ok",
    "code",
    "enabled",
    "publishedCount",
    "conflictCount",
    "failedCount",
    "deferredCount"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string", "minLength": 1 },
    "ok": { "type": "boolean" },
    "code": { "type": "string", "minLength": 1 },
    "enabled": { "type": "boolean" },
    "publishedCount": { "type": "integer", "minimum": 0 },
    "conflictCount": { "type": "integer", "minimum": 0 },
    "failedCount": { "type": "integer", "minimum": 0 },
    "deferredCount": { "type": "integer", "minimum": 0 }
  }
}
