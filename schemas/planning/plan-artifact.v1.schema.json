{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workflow-cannon.dev/schemas/planning/plan-artifact.v1.json",
  "title": "PlanArtifact v1",
  "description": "Structured planning document for Workflow Cannon. Field spec: PLANNER_SCHEMA.md.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "planId",
    "version",
    "planRef",
    "status",
    "identity",
    "goals",
    "nonGoals",
    "valueAssessment",
    "riskAssessment",
    "technicalImpact",
    "testingStrategy",
    "implementationGuidance",
    "whatNotToDo",
    "assumptions",
    "openQuestions",
    "wbs",
    "phaseRecommendations",
    "provenance"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "planId": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "planRef": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["draft", "reviewed", "accepted", "finalized", "superseded", "cancelled"]
    },
    "identity": { "$ref": "#/$defs/identity" },
    "goals": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "nonGoals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "userStories": {
      "type": "array",
      "items": { "$ref": "#/$defs/userStory" }
    },
    "valueAssessment": { "$ref": "#/$defs/valueAssessment" },
    "riskAssessment": {
      "type": "array",
      "items": { "$ref": "#/$defs/riskItem" }
    },
    "technicalImpact": { "$ref": "#/$defs/technicalImpact" },
    "architecture": { "$ref": "#/$defs/architecture" },
    "uiUxDirection": { "$ref": "#/$defs/uiUxDirection" },
    "testingStrategy": { "$ref": "#/$defs/testingStrategy" },
    "implementationGuidance": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "whatNotToDo": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "openQuestions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "wbs": {
      "type": "array",
      "items": {
        "$ref": "https://workflow-cannon.dev/schemas/planning/plan-artifact-wbs-item.v1.json"
      }
    },
    "phaseRecommendations": {
      "type": "array",
      "items": { "$ref": "#/$defs/phaseRecommendation" },
      "minItems": 1
    },
    "taskGenerationPayloads": {
      "type": "array",
      "items": {
        "$ref": "https://workflow-cannon.dev/schemas/planning/plan-artifact-wbs-item.v1.json#/$defs/generatedTaskPayload"
      }
    },
    "executionLinkage": { "$ref": "#/$defs/executionLinkage" },
    "approvalRecord": { "$ref": "#/$defs/approvalRecord" },
    "executionLinkages": {
      "type": "array",
      "items": { "$ref": "#/$defs/executionLinkage" }
    },
    "provenance": { "$ref": "#/$defs/provenance" }
  },
  "$defs": {
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "planningType": {
      "type": "string",
      "enum": ["task-breakdown", "sprint-phase", "task-ordering", "new-feature", "change"]
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "planningType"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "planningType": { "$ref": "#/$defs/planningType" },
        "summary": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "userStory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "asA", "iWant", "soThat", "priority"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "asA": { "type": "string", "minLength": 1 },
        "iWant": { "type": "string", "minLength": 1 },
        "soThat": { "type": "string", "minLength": 1 },
        "priority": {
          "type": "string",
          "enum": ["must", "should", "could"]
        }
      }
    },
    "valueAssessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["impact", "confidence"],
      "properties": {
        "impact": { "type": "string", "minLength": 1 },
        "confidence": { "$ref": "#/$defs/confidence" },
        "rationale": { "type": "string" }
      }
    },
    "riskItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "severity"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "severity": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "mitigation": { "type": "string" }
      }
    },
    "technicalImpact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["systemsTouched"],
      "properties": {
        "systemsTouched": {
          "type": "array",
          "items": { "type": "string" }
        },
        "compatibilityNotes": { "type": "string" },
        "migrationImpact": { "type": "string" }
      }
    },
    "architecture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overview"],
      "properties": {
        "overview": { "type": "string", "minLength": 1 },
        "decisions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "decision", "rationale"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "decision": { "type": "string", "minLength": 1 },
              "rationale": { "type": "string", "minLength": 1 }
            }
          }
        },
        "diagrams": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title"],
            "properties": {
              "title": { "type": "string", "minLength": 1 },
              "mermaid": { "type": "string" },
              "caption": { "type": "string" }
            }
          }
        }
      }
    },
    "uiUxDirection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hasUiChanges"],
      "properties": {
        "hasUiChanges": { "type": "boolean" },
        "summary": { "type": "string" },
        "mockupRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "testingStrategy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layers", "criticalPaths"],
      "properties": {
        "layers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "criticalPaths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "outOfScopeTesting": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "phaseRecommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phaseKey", "label", "rationale"],
      "properties": {
        "phaseKey": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "rationale": { "type": "string", "minLength": 1 },
        "isPrimary": { "type": "boolean" }
      }
    },
    "executionLinkage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "taskId",
        "linkedAt",
        "linkedBy",
        "planVersion",
        "evidenceBundle"
      ],
      "properties": {
        "schemaVersion": { "const": 1 },
        "taskId": { "type": "string", "minLength": 1 },
        "wbsId": { "type": "string", "minLength": 1 },
        "linkedAt": { "type": "string", "minLength": 1 },
        "linkedBy": { "type": "string", "minLength": 1 },
        "planVersion": { "type": "integer", "minimum": 1 },
        "approvedPlanVersion": { "type": "integer", "minimum": 1 },
        "evidenceBundle": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schemaVersion",
            "command",
            "planId",
            "planRef",
            "planRevision",
            "taskId",
            "linkedAt",
            "linkedBy"
          ],
          "properties": {
            "schemaVersion": { "const": 1 },
            "command": { "const": "execute-plan-artifact" },
            "planId": { "type": "string", "minLength": 1 },
            "planRef": { "type": "string", "minLength": 1 },
            "planRevision": { "type": "integer", "minimum": 1 },
            "approvedPlanVersion": { "type": "integer", "minimum": 1 },
            "taskId": { "type": "string", "minLength": 1 },
            "wbsId": { "type": "string", "minLength": 1 },
            "linkedAt": { "type": "string", "minLength": 1 },
            "linkedBy": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "approvalRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "confirmed",
        "approvedVersion",
        "approvedAt",
        "approvedBy",
        "planRef"
      ],
      "properties": {
        "schemaVersion": { "const": 1 },
        "confirmed": { "type": "boolean" },
        "approvedVersion": { "type": "integer", "minimum": 1 },
        "approvedAt": { "type": "string", "minLength": 1 },
        "approvedBy": { "type": "string", "minLength": 1 },
        "planRef": { "type": "string", "minLength": 1 },
        "reviewSummary": { "type": "string" },
        "openQuestionsAccepted": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["createdAt", "updatedAt", "createdBy", "source"],
      "properties": {
        "createdAt": { "type": "string", "minLength": 1 },
        "updatedAt": { "type": "string", "minLength": 1 },
        "createdBy": { "type": "string", "minLength": 1 },
        "source": {
          "type": "string",
          "enum": ["draft-plan-artifact", "import-build-plan", "import-ideas"]
        },
        "chatSessionRef": { "type": "string" },
        "parentPlanId": { "type": "string" },
        "sourceIdeaId": { "type": "string", "minLength": 1 },
        "previousPlanArtifacts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "sourceAnswers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
